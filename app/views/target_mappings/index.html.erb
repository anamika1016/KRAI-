<% content_for :title, @vrp_target_view ? "VRP Targets" : "Target Mapping Master" %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow"><%= @vrp_target_view ? "VRP Targets" : "Target Mapping Master" %></p>
        <h1><%= @vrp_target_view ? "Recent Target Mappings" : "Target Mapping" %></h1>
      </div>
    </div>

    <% unless @vrp_target_view %>
      <section class="module-card target-mapping-card"
        data-target-mapping
        data-edit-target="<%= json_escape(@edit_payload.to_json) %>"
        data-target-sub-activity-map="<%= json_escape(@target_sub_activity_map.to_json) %>"
        data-mappings-url="<%= vrp_mappings_target_mappings_path %>">
        <%= form_with url: target_mappings_path, method: :post, local: true, html: { class: "module-entry-form" } do %>
          <% if @edit_target %>
            <input type="hidden" name="target_mapping[id]" value="<%= @edit_target.id %>">
          <% end %>
          <div class="module-form-grid user-registration-grid">
            <label>
              <span>VRP <em>*</em></span>
              <select name="target_mapping[vrp_id]" data-target-vrp required>
                <option value="">Select VRP</option>
                <% @vrps.each do |vrp| %>
                  <option value="<%= vrp.id %>" <%= "selected" if @edit_target&.vrp_id == vrp.id %>><%= [vrp.name, vrp.mobile_no.presence].compact.join(" - ") %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>FCO Name <em>*</em></span>
              <select name="target_mapping[fco_id]" data-target-fco data-selected-value="<%= [@edit_target&.fco_id, @edit_target&.fco_name].compact_blank.join("||") %>" required>
                <option value="">Select FCO Name</option>
              </select>
            </label>

            <label>
              <span>ICS <em>*</em></span>
              <select name="target_mapping[ics_id]" data-target-ics data-selected-value="<%= [@edit_target&.ics_id, @edit_target&.ics_name].compact_blank.join("||") %>" required disabled>
                <option value="">Select ICS</option>
              </select>
            </label>

            <label>
              <span>Village <em>*</em></span>
              <select name="target_mapping[village_id]" data-target-village data-selected-value="<%= [@edit_target&.village_id, @edit_target&.village_name].compact_blank.join("||") %>" required disabled>
                <option value="">Select Village</option>
              </select>
            </label>

            <label>
              <span>Month <em>*</em></span>
              <select name="target_mapping[month_name]" required>
                <option value="">Select Month</option>
                <% @month_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if @edit_target&.month_name.to_s == option.to_s %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Completion Date <em>*</em></span>
              <input type="date" name="target_mapping[completion_date]" value="<%= @edit_target&.completion_date&.strftime("%Y-%m-%d") %>" required>
            </label>

            <label>
              <span>Main Activity <em>*</em></span>
              <select name="target_mapping[main_activity_name]" required>
                <option value="">Select Main Activity</option>
                <% @main_activity_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if @edit_target&.main_activity_name.to_s == option.to_s %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Sub Activity <em>*</em></span>
              <select name="target_mapping[activity_name]" required>
                <option value="">Select Sub Activity</option>
                <% @sub_activity_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if @edit_target&.activity_name.to_s == option.to_s %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Registered Farmers</span>
              <input type="text" value="0" data-target-registered-count readonly>
            </label>

            <label>
              <span>Target <em>*</em></span>
              <input type="number" name="target_mapping[target_quantity]" min="1" step="1" placeholder="Selected farmer count" value="<%= @edit_target&.target_quantity %>" data-target-quantity-input readonly required>
            </label>
          </div>

        <div class="target-farmer-panel" data-target-farmer-panel>
          <div class="target-mapping-toolbar">
            <strong>Farmer List</strong>
            <label class="vrp-ics-select-all">
              <input type="checkbox" data-target-farmer-select-all>
              <span>Select all</span>
            </label>
            <span data-target-farmer-count>0 farmer selected</span>
          </div>
          <div class="vrp-ics-farmer-list target-farmer-list" data-target-farmer-list>
            Select FCO Name, ICS and Village to load farmers.
          </div>
        </div>

        <div class="module-form-actions">
          <% if @edit_target %>
            <%= link_to "Cancel Edit", target_mappings_path, class: "btn btn-secondary" %>
          <% end %>
          <button type="submit" class="list-btn upload"><%= @edit_target ? "Update Target" : "Save Target" %></button>
        </div>
        <% end %>
      </section>
    <% end %>

	    <div class="vrp-list-card">
	      <% show_mapping_actions = @admin_mapping_actions || @remove_mapping_actions %>
	      <div class="list-controls">
        <strong>Recent Target Mappings</strong>
        <div class="list-control-actions">
          <div class="list-search compact">
            <span>⌕</span>
            <input type="search" placeholder="Search targets" data-table-search="target_mapping_list">
          </div>
        </div>
      </div>
      <div class="table-shell">
        <table class="module-table vrp-list-table" id="target_mapping_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th>VRP</th>
              <th>FCO</th>
              <th>ICS</th>
              <th>Village</th>
              <th>Farmers</th>
              <th>Month</th>
              <th>Completion Date</th>
              <th>Main Activity</th>
              <th>Sub Activity</th>
              <th>Target</th>
	              <% if show_mapping_actions %>
	                <th>Action</th>
	              <% end %>
            </tr>
          </thead>
          <tbody>
            <% if @target_mappings.any? %>
              <% @target_mappings.each do |target| %>
                <tr>
                  <td><%= target.vrp&.name %></td>
                  <td><%= target.fco_name.presence || target.fco_id %></td>
                  <td><%= target.ics_name.presence || target.ics_id %></td>
                  <td><%= target.village_name.presence || target.village_id %></td>
                  <td><%= target.farmer_count %></td>
                  <td><%= target.month_name %></td>
                  <td><%= target.completion_date&.strftime("%d-%m-%Y") || "-" %></td>
                  <td><%= target.main_activity_name %></td>
                  <td><%= target.activity_name %></td>
                  <td><%= target.target_quantity %></td>
	                  <% if show_mapping_actions %>
	                    <td>
	                      <div class="table-actions">
	                        <% if @admin_mapping_actions %>
	                          <%= link_to "Edit", target_mappings_path(edit_id: target.id), class: "table-action" %>
	                          <%= button_to "Delete", target_mapping_path(target), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this target mapping?" } } %>
	                        <% elsif @remove_mapping_actions %>
	                          <%= button_to "Remove", target_mapping_path(target), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Remove this target mapping?" } } %>
	                        <% end %>
	                      </div>
	                    </td>
	                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <tr>
	                <td colspan="<%= show_mapping_actions ? 11 : 10 %>">No target mapping saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="target_mapping_list"></div>
    </div>
  </section>
</main>
