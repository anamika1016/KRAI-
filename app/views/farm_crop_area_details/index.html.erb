<% content_for :title, "Farm-Crop-Area Details" %>
<% form_record = @farm_crop_area_detail %>
<% form_url = form_record.persisted? ? farm_crop_area_detail_path(form_record) : farm_crop_area_details_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Farmer Farm Information</p>
        <h1>Farm-Crop-Area Details</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_farm_crop_area_details_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_farm_crop_area_details_path, class: "list-btn export" %>
        </div>
      </div>
    </div>

    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Record Name</span>
            <%= f.text_field :record_title, placeholder: "Enter Record Name" %>
          </label>
          <label>
            <span>Name of the crop</span>
            <%= f.text_field :crop_name, placeholder: "Enter Crop Name" %>
          </label>
          <label>
            <span>Area in Hectares</span>
            <%= f.number_field :area_hectares, step: "0.0001", min: 0, placeholder: "Enter Area" %>
          </label>
          <label>
            <span>Year and season of production</span>
            <%= f.text_field :year_season_production, placeholder: "Enter Year and Season" %>
          </label>
          <label>
            <span>Age and plantation time in case of perennial</span>
            <%= f.text_field :perennial_age_plantation_time, placeholder: "Enter Age and Plantation Time" %>
          </label>
          <label>
            <span>Method of production</span>
            <%= f.text_field :production_method, placeholder: "Irrigated / Non-irrigated" %>
          </label>
          <label>
            <span>Remarks</span>
            <%= f.text_field :remarks, placeholder: "Organic / In-conversion / Others" %>
          </label>
          <label>
            <span>Status</span>
            <%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %>
          </label>
        </div>

        <div class="module-form-actions">
          <% if form_record.persisted? %>
            <%= link_to "Cancel Edit", farm_crop_area_details_path, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to "Clear", farm_crop_area_details_path, class: "btn btn-secondary" %>
          <% end %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search farm crop area details" data-table-search="farm_crop_area_details_list">
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="farm_crop_area_details_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Record Name</th>
              <th>Name of the crop</th>
              <th>Area in Hectares</th>
              <th>Year and season</th>
              <th>Method</th>
              <th>Remarks</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @farm_crop_area_details.any? %>
              <% @farm_crop_area_details.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_farm_crop_area_detail_path(record) %>" data-module-row-select></td>
                  <td><%= record.record_title.presence || "-" %></td>
                  <td><%= record.crop_name.presence || "-" %></td>
                  <td><%= record.area_hectares.presence || "-" %></td>
                  <td><%= record.year_season_production.presence || "-" %></td>
                  <td><%= record.production_method.presence || "-" %></td>
                  <td><%= record.remarks.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8">No farm crop area details saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="farm_crop_area_details_list"></div>
    </section>
  </section>
</main>
