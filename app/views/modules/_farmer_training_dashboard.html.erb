<% quantity = ->(value) { value.to_f == value.to_i ? value.to_i : format("%.2f", value.to_f) } %>
<% rows = Array(training_rows) %>
<% totals = participation[:totals] || {} %>
<% month_options = Array(@training_month_options || []) %>
<% sub_activity_options = Array(@training_sub_activity_options || []) %>
<% selected_month = @training_selected_month.to_s %>
<% selected_sub_activity = @training_selected_sub_activity.to_s %>
<% filters_ready = selected_month.present? && selected_sub_activity.present? %>

<section class="module-card training-dashboard-card">
  <div class="module-card-header training-dashboard-header">
    <div>
      <h2>Farmer Training Dashboard</h2>
      <p>Live month-wise target, activity, and farmer status.</p>
    </div>
    <div class="training-dashboard-header-actions">
      <%= form_with url: dashboard_path, method: :get, local: true, html: { class: "dashboard-month-filter training-dashboard-month-filter" } do %>
        <div class="training-dashboard-filter-group">
          <label class="dashboard-month-select">
            <span>Month</span>
            <select name="training_month" data-dashboard-training-filter-select data-dashboard-training-month-select>
              <option value="">Select Month</option>
              <% month_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if selected_month == option.to_s %>><%= option %></option>
              <% end %>
            </select>
          </label>
          <label class="dashboard-month-select">
            <span>Sub Activity</span>
            <select name="training_sub_activity" data-dashboard-training-filter-select data-dashboard-training-sub-activity-select <%= "disabled" if selected_month.blank? %>>
              <option value="">Select Sub Activity</option>
              <% sub_activity_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if selected_sub_activity == option.to_s %>><%= option %></option>
              <% end %>
            </select>
          </label>
        </div>
      <% end %>
      <% if filters_ready %>
        <div class="training-dashboard-total">
          <span>Total Farmers</span>
          <strong><%= totals[:total].to_i %></strong>
        </div>
      <% end %>
    </div>
  </div>

  <% if filters_ready %>
    <div class="training-dashboard-summary">
      <article class="training-summary-pill green">
        <span>Green</span>
        <strong><%= totals[:green].to_i %></strong>
      </article>
      <article class="training-summary-pill yellow">
        <span>Yellow</span>
        <strong><%= totals[:yellow].to_i %></strong>
      </article>
      <article class="training-summary-pill red">
        <span>Red</span>
        <strong><%= totals[:red].to_i %></strong>
      </article>
      <article class="training-summary-pill neutral">
        <span>Monthly Unique</span>
        <strong><%= totals[:monthly_unique].to_i %></strong>
      </article>
    </div>

    <div class="training-dashboard-grid">
      <% if rows.any? %>
      <div class="table-shell compact-scroll">
        <table class="module-table compact-table training-activity-table">
          <thead>
            <tr>
              <th>Month</th>
              <th>ICS</th>
              <th>Village</th>
              <th>Main Activity</th>
              <th>Sub Activity</th>
              <th>Green</th>
              <th>Yellow</th>
              <th>Red</th>
              <th>Total Farmers</th>
              <th>Target</th>
              <th>Completed</th>
              <th>Pending</th>
              <th>Progress</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            <% rows.each_with_index do |row, index| %>
              <% detail_id = "training_row_detail_#{index}" %>
              <tr>
                <td><%= row[:month].presence || "-" %></td>
                <td><%= row[:ics].presence || "-" %></td>
                <td><%= row[:village].presence || "-" %></td>
                <td><%= row[:activity].presence || "-" %></td>
                <td><%= row[:sub_activity].presence || "-" %></td>
                <td><span class="training-status-pill green"><%= row[:green].to_i %></span></td>
                <td><span class="training-status-pill yellow"><%= row[:yellow].to_i %></span></td>
                <td><span class="training-status-pill red"><%= row[:red].to_i %></span></td>
                <td><%= row[:total].to_i %></td>
                <td><%= quantity.call(row[:target_quantity]) %></td>
                <td><%= quantity.call(row[:completed_quantity]) %></td>
                <td><%= quantity.call(row[:pending_quantity]) %></td>
                <td>
                  <div class="training-progress compact">
                    <div style="width: <%= row[:progress_percent].to_i.clamp(0, 100) %>%"></div>
                  </div>
                  <small><%= row[:progress_percent].to_i %>%</small>
                </td>
                <td>
                  <button type="button" class="training-row-toggle table-action" data-training-row-toggle data-training-row-target="<%= detail_id %>" aria-expanded="false">
                    View
                  </button>
                </td>
              </tr>
              <tr id="<%= detail_id %>" hidden data-training-row-details>
                <td colspan="14">
                  <% completed_farmer_count = row[:completed_quantity].to_i %>
                  <% pending_farmer_count = row[:pending_quantity].to_i %>
                  <% farmer_count_total = completed_farmer_count + pending_farmer_count %>
                  <% row_status_class = pending_farmer_count.zero? ? "green" : (completed_farmer_count.positive? ? "yellow" : "red") %>
                  <div class="training-row-details">
                    <div class="training-row-details-header">
                      <div>
                        <h3><%= row[:activity].presence || "Farmer Training" %></h3>
                        <p>
                          <%= row[:month].presence || "-" %> &middot;
                          <%= row[:ics].presence || "-" %> &middot;
                          <%= row[:village].presence || "-" %> &middot;
                          <%= row[:sub_activity].presence || "-" %>
                        </p>
                        <p>Completed Farmers: <%= completed_farmer_count %> &middot; Pending Farmers: <%= pending_farmer_count %></p>
                      </div>
                      <span class="training-status-pill <%= row_status_class %>">
                        <%= completed_farmer_count %>/<%= farmer_count_total %>
                      </span>
                    </div>
                    <div class="table-shell compact-scroll">
                      <table class="module-table compact-table">
                        <thead>
                          <tr>
                            <th>ICS</th>
                            <th>Village</th>
                            <th>Main Activity</th>
                            <th>Sub Activity</th>
                            <th>Target Farmers</th>
                            <th>Completed</th>
                            <th>Pending</th>
                            <th>Status</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% Array(row[:target_rows]).each do |target_row| %>
                            <tr>
                              <td><%= target_row[:ics] %></td>
                              <td><%= target_row[:village] %></td>
                              <td><%= target_row[:main_activity] %></td>
                              <td><%= target_row[:sub_activity] %></td>
                              <td><%= quantity.call(target_row[:target_quantity]) %></td>
                              <td><%= quantity.call(target_row[:completed_quantity]) %></td>
                              <td><%= quantity.call(target_row[:pending_quantity]) %></td>
                              <td><span class="training-status-pill <%= target_row[:status_class] %>"><%= target_row[:status_label] %></span></td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                    <div class="training-row-panels">
                      <div class="training-row-panel">
                        <h4>Completed Farmers</h4>
                        <div class="table-shell compact-scroll">
                          <table class="module-table compact-table">
                            <thead>
                              <tr>
                                <th>Farmer</th>
                                <th>ICS</th>
                                <th>Village</th>
                                <th>Main Activity</th>
                                <th>Sub Activity</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% Array(row[:completed_farmers]).each do |farmer| %>
                                <tr>
                                  <td><%= farmer[:farmer_name] %></td>
                                  <td><%= row[:ics].presence || "-" %></td>
                                  <td><%= row[:village].presence || "-" %></td>
                                  <td><%= row[:activity].presence || "-" %></td>
                                  <td><%= row[:sub_activity].presence || "-" %></td>
                                </tr>
                              <% end %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                      <div class="training-row-panel">
                        <h4>Pending Farmers</h4>
                        <div class="table-shell compact-scroll">
                          <table class="module-table compact-table">
                            <thead>
                              <tr>
                                <th>Farmer</th>
                                <th>ICS</th>
                                <th>Village</th>
                                <th>Main Activity</th>
                                <th>Sub Activity</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% Array(row[:pending_farmers]).each do |farmer| %>
                                <tr>
                                  <td><%= farmer[:farmer_name] %></td>
                                  <td><%= row[:ics].presence || "-" %></td>
                                  <td><%= row[:village].presence || "-" %></td>
                                  <td><%= row[:activity].presence || "-" %></td>
                                  <td><%= row[:sub_activity].presence || "-" %></td>
                                </tr>
                              <% end %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% else %>
        <div class="training-empty-state">No farmer training target and attendance data found.</div>
      <% end %>
    </div>
  <% else %>
    <div class="training-empty-state">Select Month and Sub Activity to load training data.</div>
  <% end %>
</section>
