<% content_for :title, "#{@training_participation_title} Farmer Training List" %>
<% filter_params = {
  training_month: @training_selected_month.presence,
  training_sub_activity: @training_selected_sub_activity.presence
}.compact_blank %>
<% status_counts = @training_participation_totals || { green: 0, yellow: 0, red: 0, pending: 0, total: 0 } %>

<section class="dashboard-page">
  <div class="dashboard-topbar">
    <div>
      <p class="vrp-eyebrow">Farmer Training Participation Status</p>
      <h1><%= @training_participation_title %> Farmers</h1>
      <p><%= @training_participation_caption %></p>
    </div>

    <div class="dashboard-actions">
      <%= link_to "Back to Dashboard", dashboard_path(filter_params), class: "list-btn active" %>
      <%= link_to "Export CSV", farmer_training_participation_path(filter_params.merge(status: @training_participation_status, format: :csv)), class: "list-btn export" %>
    </div>
  </div>

  <section class="module-card training-participation-status-card">
    <div class="training-participation-boxes compact">
      <%= link_to farmer_training_participation_path(filter_params.merge(status: "total")), class: "training-participation-box total #{'is-active' if @training_participation_status == 'total'}" do %>
        <span>Total Mapped Farmer</span>
        <strong><%= status_counts[:total].to_i %></strong>
        <small>Farmer Target Form ke selected farmers.</small>
      <% end %>
      <% %w[green yellow red pending].each do |status| %>
        <%= link_to farmer_training_participation_path(filter_params.merge(status: status)), class: "training-participation-box #{status} #{'is-active' if @training_participation_status == status}" do %>
          <span><%= status == "pending" ? "Pending Farmer" : training_participation_status_label(status) %></span>
          <strong><%= status_counts[status.to_sym].to_i %></strong>
          <small><%= training_participation_status_caption(status) %></small>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="module-card">
    <div class="module-card-header">
      <div>
        <h2><%= @training_participation_title %> Farmer List</h2>
        <p class="module-subtitle">
          Total: <%= @training_participation_rows.size %>
          <% if @training_selected_month.present? %>
            | Month: <%= @training_selected_month %>
          <% end %>
          <% if @training_selected_sub_activity.present? %>
            | Sub Activity: <%= @training_selected_sub_activity %>
          <% end %>
        </p>
      </div>
      <button type="button" class="list-btn export" data-export-table="training_participation_list">Export</button>
    </div>

    <div class="table-shell">
      <table class="module-table compact-table training-participation-table" id="training_participation_list" data-paginated-table data-page-size="20">
        <thead>
          <tr>
            <th>Farmer</th>
            <th>Mobile</th>
            <th>TraceNet No</th>
            <th>ICS</th>
            <th>Village</th>
            <th>VRP</th>
            <th>Target Month</th>
            <th>Main Activity</th>
            <th>Sub Activity</th>
            <th>Training Count</th>
            <th>Status</th>
            <th>Training Dates</th>
            <th>Last Training Date</th>
          </tr>
        </thead>
        <tbody>
          <% if @training_participation_rows.any? %>
            <% @training_participation_rows.each do |row| %>
              <tr>
                <td>
                  <%= row[:farmer_name] %>
                  <% if row[:father_name].present? %>
                    <small>Father: <%= row[:father_name] %></small>
                  <% end %>
                </td>
                <td><%= row[:mobile_no].presence || "-" %></td>
                <td><%= row[:tracenet_no].presence || "-" %></td>
                <td><%= row[:ics].presence || "-" %></td>
                <td><%= row[:village].presence || "-" %></td>
                <td><%= row[:vrp].presence || "-" %></td>
                <td><%= row[:months].presence || "-" %></td>
                <td><%= row[:main_activities].presence || "-" %></td>
                <td><%= row[:sub_activities].presence || "-" %></td>
                <td><%= row[:attendance_count].to_i %></td>
                <td><span class="training-status-pill <%= row[:status] %>"><%= row[:status_label] %></span></td>
                <td><%= row[:training_dates].presence || "-" %></td>
                <td><%= row[:last_training_date].presence || "-" %></td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="13">No farmers found for this status.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="table-pagination" data-pagination-for="training_participation_list"></div>
  </section>
</section>
