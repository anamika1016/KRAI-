<% content_for :title, "Dashboard" %>

<% if @vrp_dashboard %>
  <% quantity = ->(value) { value.to_f == value.to_i ? value.to_i : format("%.2f", value.to_f) } %>
  <section class="dashboard-page">
    <div class="dashboard-topbar">
      <div>
        <p class="vrp-eyebrow">VRP Dashboard</p>
        <h1><%= @vrp&.name.presence || current_app_user["name"].presence || "Dashboard" %></h1>
        <p>Your mapped farmers, villages, assigned targets, and completed work summary.</p>
      </div>

      <div class="dashboard-actions">
        <%= link_to "View Targets", target_mappings_path, class: "list-btn active" %>
      </div>
    </div>

    <div class="dashboard-grid premium">
      <% @dashboard_cards.each_with_index do |card, index| %>
        <% title = card.is_a?(Hash) ? card[:title] : card[0] %>
        <% value = card.is_a?(Hash) ? card[:value] : card[1] %>
        <% caption = card.is_a?(Hash) ? card[:caption] : card[2] %>
        <% path = card.is_a?(Hash) && card[:path].present? ? card[:path] : target_mappings_path %>
        <%= link_to path, class: "metric-card-link", data: { dashboard_card: true } do %>
          <article class="metric-card <%= "featured" if index.zero? %>">
            <div>
              <span><%= title %></span>
              <strong><%= value %></strong>
              <small><%= caption %></small>
            </div>
            <b>↗</b>
          </article>
        <% end %>
      <% end %>
    </div>

    <% participation = @training_participation || { totals: { green: 0, yellow: 0, red: 0, total: 0 }, ics_rows: [], village_rows: [] } %>
    <% training_rows = @farmer_training_dashboard_rows || [] %>
    <%= render "farmer_training_dashboard", training_rows: training_rows, participation: participation %>

    <section class="module-card" id="vrp_target_progress">
      <div class="module-card-header">
        <h2>Assigned Target Progress</h2>
        <button type="button" class="list-btn export" data-export-table="vrp_target_progress_table">Export</button>
      </div>

      <div class="table-shell">
        <table class="module-table compact-table" id="vrp_target_progress_table" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th>Month</th>
              <th>FCO</th>
              <th>Village</th>
              <th>Farmers</th>
              <th>Main Activity</th>
              <th>Sub Activity</th>
              <th>Target</th>
              <th>Completed</th>
              <th>Pending</th>
              <th>Progress</th>
            </tr>
          </thead>
          <tbody>
            <% if @vrp_target_rows.any? %>
              <% @vrp_target_rows.each do |row| %>
                <tr>
                  <td><%= row[:month] %></td>
                  <td><%= row[:fco] %></td>
                  <td><%= row[:village] %></td>
                  <td><%= row[:farmers] %></td>
                  <td><%= row[:main_activity] %></td>
                  <td><%= row[:activity] %></td>
                  <td><%= quantity.call(row[:target]) %></td>
                  <td><%= quantity.call(row[:completed]) %></td>
                  <td><%= quantity.call(row[:pending]) %></td>
                  <td><span class="grid-status <%= row[:pending].to_f.zero? ? "approved" : "pending" %>"><%= row[:progress] %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="10">No target has been assigned to this VRP yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="vrp_target_progress_table"></div>
    </section>

    <% followup = @vrp_farmer_followup || { repeat: [], new: [], pending: [], current_month: Date.current.beginning_of_month, previous_month: Date.current.prev_month.beginning_of_month } %>
    <% farmer_sections = [
      ["Repeat Farmers", followup[:repeat], "Worked in #{followup[:previous_month].strftime("%B")} and again in #{followup[:current_month].strftime("%B")}"],
      ["New Farmers", followup[:new], "Worked in #{followup[:current_month].strftime("%B")} but not in #{followup[:previous_month].strftime("%B")}"],
      ["Pending Target Farmers", followup[:pending], "Mapped or targeted farmers not covered in #{followup[:current_month].strftime("%B")}"]
    ] %>
    <section class="module-card" id="vrp_farmer_followup">
      <div class="module-card-header">
        <h2>Farmer Month Follow-up</h2>
      </div>

      <div class="dashboard-report-grid">
        <% farmer_sections.each_with_index do |(title, farmers, caption), index| %>
          <article class="report-card" data-dashboard-card>
            <h3><%= title %></h3>
            <div class="farmer-followup-count">
              <strong><%= farmers.size %></strong>
              <span><%= caption %></span>
            </div>

            <div class="table-shell compact-scroll">
              <table class="module-table compact-table">
                <thead>
                  <tr>
                    <th>Farmer</th>
                    <th>Village</th>
                    <th>Mobile</th>
                    <th>Last Work Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% if farmers.any? %>
                    <% farmers.first(12).each do |farmer| %>
                      <tr>
                        <td>
                          <%= farmer[:name] %>
                          <% if farmer[:father_name].present? %>
                            <small>Father: <%= farmer[:father_name] %></small>
                          <% end %>
                        </td>
                        <td><%= farmer[:village].presence || "-" %></td>
                        <td><%= farmer[:mobile_no].presence || "-" %></td>
                        <td><%= farmer[:work_date]&.strftime("%d-%m-%Y") || "-" %></td>
                      </tr>
                    <% end %>
                  <% else %>
                    <tr>
                      <td colspan="4">No farmers in this list.</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="module-card" id="vrp_mapped_villages">
      <div class="module-card-header">
        <h2>Mapped Village Work Area</h2>
      </div>

      <div class="table-shell">
        <table class="module-table compact-table">
          <thead>
            <tr>
              <th>FCO</th>
              <th>Gram Panchayat</th>
              <th>Village</th>
              <th>Mapped Farmers</th>
              <th>Targets</th>
              <th>Target Quantity</th>
            </tr>
          </thead>
          <tbody>
            <% if @vrp_village_rows.any? %>
              <% @vrp_village_rows.each do |row| %>
                <tr>
                  <td><%= row[:fco] %></td>
                  <td><%= row[:gram_panchayat].presence || "-" %></td>
                  <td><%= row[:village] %></td>
                  <td><%= row[:farmers] %></td>
                  <td><%= row[:targets] %></td>
                  <td><%= quantity.call(row[:target_quantity]) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6">No village or farmer mapping found for this VRP yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </section>
<% else %>
<section class="dashboard-page">
  <div class="dashboard-topbar">
    <div>
      <p class="vrp-eyebrow">Dashboard Module</p>
      <h1><%= @dashboard_title.presence || "Dashboard" %></h1>
      <p><%= @dashboard_caption.presence || "Live system summary." %></p>
    </div>

    <div class="dashboard-actions">
      <div class="list-search">
        <span>⌕</span>
        <input type="search" placeholder="Search dashboard" data-dashboard-search>
      </div>
      <label class="import-btn">
        Import Data
        <input type="file" accept=".csv,.xlsx,.xls" data-import-file hidden>
      </label>
    </div>
  </div>

  <div class="dashboard-grid premium">
    <% @dashboard_cards.each_with_index do |card, index| %>
      <% title = card.is_a?(Hash) ? card[:title] : card[0] %>
      <% value = card.is_a?(Hash) ? card[:value] : card[1] %>
      <% caption = card.is_a?(Hash) ? card[:caption] : card[2] %>
      <% path = card.is_a?(Hash) && card[:path].present? ? card[:path] : dashboard_path %>
      <%= link_to path, class: "metric-card-link", data: { dashboard_card: true } do %>
        <article class="metric-card <%= "featured" if index.zero? %>">
          <div>
            <span><%= title %></span>
            <strong><%= value %></strong>
            <small><%= caption %></small>
          </div>
          <b>↗</b>
        </article>
      <% end %>
    <% end %>
  </div>

  <% participation = @training_participation || { totals: { green: 0, yellow: 0, red: 0, total: 0 }, ics_rows: [], village_rows: [] } %>
  <% training_rows = @farmer_training_dashboard_rows || [] %>
  <%= render "farmer_training_dashboard", training_rows: training_rows, participation: participation %>

  <section class="module-card">
    <div class="module-card-header">
      <h2>Dashboard Reports</h2>
      <button type="button" class="list-btn export" data-export-table="dashboard_reports">Export</button>
    </div>

    <div class="dashboard-report-grid" id="dashboard_reports">
      <% @dashboard_reports.each do |report| %>
        <article class="report-card <%= "clock-report-card" if report[:clock] %>" <%= "id=\"#{report[:dom_id]}\"".html_safe if report[:dom_id].present? %> data-dashboard-card>
          <% if report[:clock] %>
            <h3><%= report[:title] %></h3>
            <div class="dashboard-clock-face">
              <div class="clock-content">
                <div class="clock-info">
                  <span class="clock-hud-label">Live</span>
                  <strong data-dashboard-clock-time><%= @dashboard_generated_at.strftime("%I:%M:%S %p") %></strong>
                  <small data-dashboard-clock-date><%= @dashboard_generated_at.strftime("%A, %d %B %Y") %></small>
                </div>
                <div class="clock-hud-panel">
                  <div class="clock-dial">
                    <i></i>
                    <span></span>
                  </div>
                </div>
              </div>
              <div class="clock-card-footer">
                <small>Refresh: <%= @dashboard_generated_at.strftime("%d-%m-%Y %I:%M %p") %></small>
              </div>
            </div>
          <% elsif report[:collapsible] %>
            <details class="dashboard-report-details" <%= "open" if report[:expanded] %>>
              <summary class="dashboard-report-summary">
                <h3><%= report[:title] %></h3>
                <span>▾</span>
              </summary>
              <div class="dashboard-report-body">
                <div class="table-shell compact-scroll">
                  <table class="module-table compact-table">
                    <thead>
                      <tr>
                        <% report[:headers].each do |header| %>
                          <th><%= header %></th>
                        <% end %>
                      </tr>
                    </thead>
                    <tbody>
                      <% report[:rows].each do |row| %>
                        <tr>
                          <% row.each do |value| %>
                            <td><%= value %></td>
                          <% end %>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            </details>
          <% else %>
            <h3><%= report[:title] %></h3>
            <div class="table-shell compact-scroll">
              <table class="module-table compact-table">
                <thead>
                  <tr>
                    <% report[:headers].each do |header| %>
                      <th><%= header %></th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% report[:rows].each do |row| %>
                    <tr>
                      <% row.each do |value| %>
                        <td><%= value %></td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>
</section>
<% end %>
