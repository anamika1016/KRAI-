<% content_for :title, "Dashboard" %>

<section class="dashboard-page">
  <div class="dashboard-topbar">
    <div>
      <p class="vrp-eyebrow">Dashboard Module</p>
      <h1>Dashboard</h1>
      <p>Live VRP, bill, payment, target, activity, aur training summary.</p>
    </div>

    <div class="dashboard-actions">
      <div class="list-search">
        <span>⌕</span>
        <input type="search" placeholder="Search dashboard" data-dashboard-search>
      </div>
      <label class="import-btn">
        Import Data
        <input type="file" accept=".csv,.xlsx,.xls" data-import-file hidden>
      </label>
    </div>
  </div>

  <div class="dashboard-grid premium">
    <% card_paths = {
      "Total Registered VRP" => vrps_path,
      "Final Approved VRP" => vrps_path,
      "VRP Waiting for Approval" => approvals_vrps_path,
      "Bills Created" => module_path("vrp-bill-list"),
      "Bills Pending Payment" => module_path("vrp-bill-list"),
      "Weekly Targets Assigned" => module_path("weekly-target-list"),
      "Activities Configured" => module_path("vrp-activity-list"),
      "Training Materials Uploaded" => module_path("training-material")
    } %>
    <% @dashboard_cards.each_with_index do |(title, value, caption), index| %>
      <%= link_to card_paths.fetch(title, dashboard_path), class: "metric-card-link", data: { dashboard_card: true } do %>
        <article class="metric-card <%= "featured" if index.zero? %>">
          <div>
            <span><%= title %></span>
            <strong><%= value %></strong>
            <small><%= caption %></small>
          </div>
          <b>↗</b>
        </article>
      <% end %>
    <% end %>
  </div>

  <section class="module-card">
    <div class="module-card-header">
      <h2>Dashboard Reports</h2>
      <button type="button" class="list-btn export" data-export-table="dashboard_reports">Export</button>
    </div>

    <div class="dashboard-report-grid" id="dashboard_reports">
      <% @dashboard_reports.each do |report| %>
        <article class="report-card <%= "clock-report-card" if report[:clock] %>" data-dashboard-card>
          <h3><%= report[:title] %></h3>
          <% if report[:clock] %>
            <div class="dashboard-clock-face">
              <div class="clock-content">
                <div class="clock-info">
                  <span class="clock-hud-label">Live</span>
                  <strong data-dashboard-clock-time><%= @dashboard_generated_at.strftime("%I:%M:%S %p") %></strong>
                  <small data-dashboard-clock-date><%= @dashboard_generated_at.strftime("%A, %d %B %Y") %></small>
                </div>
                <div class="clock-hud-panel">
                  <div class="clock-dial">
                    <i></i>
                    <span></span>
                  </div>
                </div>
              </div>
              <div class="clock-card-footer">
                <small>Refresh: <%= @dashboard_generated_at.strftime("%d-%m-%Y %I:%M %p") %></small>
              </div>
            </div>
          <% else %>
            <div class="table-shell compact-scroll">
              <table class="module-table compact-table">
                <thead>
                  <tr>
                    <% report[:headers].each do |header| %>
                      <th><%= header %></th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% report[:rows].each do |row| %>
                    <tr>
                      <% row.each do |value| %>
                        <td><%= value %></td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>
</section>
