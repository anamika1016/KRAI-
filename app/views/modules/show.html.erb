          <button type="button" class="list-btn export" data-export-table="<%= table_id %>">Export</button>
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table user-list-table" id="<%= table_id %>" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <% @module[:fields].each do |field| %>
                <th><%= resource_person_label(field) %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% if @records.any? %>
              <% @records.each do |record| %>
                <tr>
                  <% edit_slug = { "approval-list" => "approval-master", "access-control-list" => "access-control", "vrp-bill-list" => "vrp-bill-add", "jeevika-jankar-bill-list" => "jeevika-jankar-bill-process", "training-form-list" => "training-form", "seed-distribution-target-list" => "seed-distribution-target", "papl360-target-list" => "papl360-target" }.fetch(@slug, @slug) %>
                  <td>
                    <input type="checkbox"
                      value="<%= edit_module_record_path(edit_slug, record) %>"
                      data-module-row-select>
                  </td>
                  <% @module[:fields].each do |field| %>
                    <% field_key = field.parameterize(separator: "_") %>
                    <% value = module_record_field_value(record, field).presence || record.data[field_key].presence %>
                    <% value ||= record.data["activity_group_name"].presence if field == "Main Activity Name" %>
                    <% value ||= record.data["activity_group"].presence if field == "Main Activity" %>
                    <% value ||= record.data["activity_name"].presence || record.data["vrp_activity_name"].presence if field == "Sub Activity Name" %>
                    <% value ||= record.data["category_name"].presence || record.data["office"].presence if field == "Office Name" %>
                    <% value = record.data["select_vrp_name"].presence || value if @slug == "jeevika-jankar-bill-list" && field == "Jeevika Jankar Name" %>
                    <% value ||= Array(record.data["selected_farmer_names"]).join(", ").presence if field == "Selected Farmers" %>
                    <% if @slug == "access-control-list" && field == "Module Name" %>
                      <% value = Array(record.data["module_names"].presence || value).compact_blank %>
                    <% elsif @slug == "access-control-list" && field == "Sub Module Name" %>
                      <% value = Array(record.data["sub_module_names"].presence || record.data["sub_module_name"].presence || value).compact_blank %>
                    <% else %>
                      <% value ||= Array(record.data["module_names"]).join(", ").presence if field == "Module Name" %>
                      <% value ||= Array(record.data["sub_module_names"].presence || record.data["sub_module_name"]).join(", ").presence if field == "Sub Module Name" %>
                    <% end %>
                    <% value = value.join(", ") if value.is_a?(Array) %>
                    <% value ||= "-" %>
                    <% if field == "Status" %>
                      <td><span class="status-pill <%= value == "Inactive" ? "inactive" : "active" %>"><%= value == "-" ? "Active" : value %></span></td>
                    <% elsif @slug == "access-control-list" && ["Module Name", "Sub Module Name"].include?(field) %>
                      <% list_values = Array(value).flat_map { |item| item.to_s.split(",") }.map(&:strip).compact_blank %>
                      <td>
                        <div class="stacked-list-cell">
                          <% if list_values.any? %>
                            <% list_values.each do |item| %>
                              <span><%= item %></span>
                            <% end %>
                          <% else %>
                            <span>-</span>
                          <% end %>
                        </div>
                      </td>
                    <% else %>
                      <% if field.downcase.include?("upload") || field.downcase.include?("file") %>
                        <td>
                          <% if value.present? %>
                            <%= link_to "View", value, target: "_blank", rel: "noopener", class: "table-action" %>
                          <% else %>
                            -
                          <% end %>
                        </td>
                      <% else %>
                        <td><%= value %></td>
                      <% end %>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= @module[:fields].size + 1 %>">No records saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="<%= table_id %>"></div>
    </section>
  <% else %>
  <div class="module-grid">
    <% location_fields = ["State", "District", "Block", "Gram Panchayat", "Village"] %>
    <% has_location_fields = (@module[:fields] & location_fields).any? %>
    <% other_target_form = ["seed-distribution-target", "papl360-target"].include?(@slug) %>
    <% seed_target_form = @slug == "seed-distribution-target" %>
    <section class="module-card" id="module-form" <% if ["role-management", "role-name", "user-management-role", "person-type"].include?(@slug) %>data-user-role-form data-role-map="<%= json_escape(role_management_mappings.to_json) %>"<% end %> <% if @slug == "parent-office-add" %>data-parent-office-form data-parent-office-map="<%= json_escape(parent_office_mappings.to_json) %>"<% end %> <% if has_location_fields %>data-location-form data-location-map="<%= json_escape(location_hierarchy_mappings.to_json) %>"<% end %> <% if @slug == "training-form" %>data-training-target-form data-training-target-map="<%= json_escape(training_target_mappings.to_json) %>" data-training-activity-map="<%= json_escape(training_activity_setup_mappings.to_json) %>" data-training-month-options="<%= json_escape(training_target_month_options.to_json) %>"<% end %> <% if other_target_form %>data-seed-target-form data-seed-target-map="<%= json_escape(seed_distribution_target_mappings.to_json) %>" data-seed-month-options="<%= json_escape(seed_distribution_target_month_options.to_json) %>"<% end %>>
      <div class="module-card-header">
        <h2><%= @slug == "new-user" ? "Registration" : (@record.present? ? "Edit Record" : "Fields") %></h2>
      </div>
      <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
      <% form_method = @record.present? ? :patch : :post %>
      <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form", multipart: true } do %>
        <% if @slug == "training-form" %>
          <input type="hidden" name="module_record[main_activity_type]" value="Training" data-training-main-activity-type>
        <% end %>
        <% if other_target_form %>
          <input type="hidden" name="module_record[main_activity_type]" value="Other">
          <input type="hidden" name="module_record[target_mapping_id]" value="<%= @record&.data&.[]("target_mapping_id") %>" data-seed-target-id>
          <input type="hidden" name="module_record[jeevika_jankar_id]" value="<%= @record&.data&.[]("jeevika_jankar_id") %>" data-seed-vrp-id>
        <% end %>
        <% selected_training_farmer_ids = Array(@record&.data&.[]("selected_farmer_ids")).map(&:to_s) if @slug == "training-form" %>
        <% selected_seed_target_farmer_ids = Array(@record&.data&.[]("selected_farmer_ids")).map(&:to_s) if seed_target_form %>
        <div class="module-form-grid <%= "user-registration-grid" if @slug == "new-user" || (@slug == "all-user" && @record.present?) %>">
          <% @module[:fields].each do |field| %>
            <% field_key = field.parameterize(separator: "_") %>
            <% field_value = @record&.data&.[](field_key).to_s %>
            <% field_value = module_record_field_value(@record, field).to_s if @record.present? && field_value.blank? %>
            <% field_value = @record&.data&.[]("role_name").to_s if field == "Role" && field_value.blank? %>
            <% field_value = (@record&.data&.[]("category_name").presence || @record&.data&.[]("office")).to_s if field == "Office Name" && field_value.blank? %>
            <% field_value = "Training" if @slug == "add-activity-group" && field == "Main Activity Type" && field_value.blank? %>
            <% field_value = "Training" if @slug == "training-form" && field == "Main Activity Type" && field_value.blank? %>
            <% field_value = "Auto Fill" if @slug == "add-activity-group" && field == "Achievement Fill" && field_value.blank? %>
            <% if @slug == "parent-office-add" && field == "Parent Office Type" && field_value.blank? %>
              <% field_value = @record&.data&.[]("parent_office").present? ? "Sub Parent Office" : "Parent Office" if @record.present? %>
            <% end %>
            <% if @slug == "training-form" && field_value.blank? %>
              <% field_value = training_trainee_department_default if field == "Trainee Department" %>
              <% field_value = current_app_user&.dig("name").to_s if field == "Trainer Name" %>
              <% field_value = current_app_user&.dig("mobile_no").to_s if field == "Trainer Contact" %>
              <% field_value = selected_training_farmer_ids.size.to_s if field == "Farmer Count" && selected_training_farmer_ids.present? %>
            <% end %>
            <% if other_target_form && field == "Contact Number" && field_value.blank? %>
              <% field_value = @record&.data&.[]("jeevika_jankar_contact").to_s %>
            <% end %>
            <% if other_target_form && field == "Department" && field_value.blank? %>
              <% field_value = @record&.data&.[]("fcoc_name").to_s %>
            <% end %>
            <% if seed_target_form && field == "Farmer Count" && field_value.blank? %>
              <% field_value = selected_seed_target_farmer_ids.size.to_s if selected_seed_target_farmer_ids.present? %>
            <% end %>
            <% if other_target_form && @record.blank? && field == "Completion Date" && field_value.blank? %>
              <% field_value = Date.current.to_s %>
            <% end %>
            <% form_required = @slug == "training-form" || other_target_form %>
            <% required_attr = form_required ? "required" : nil %>
            <label>
              <span>
                <%= resource_person_label(field) %>
                <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
                  <small class="field-hint inline-upload-hint">Max 5 MB</small>
                <% end %>
              </span>
              <% if field.downcase.include?("status") %>
                <select name="module_record[<%= field_key %>]">
                  <option <%= "selected" if field_value == "Active" %>>Active</option>
                  <option <%= "selected" if field_value == "Inactive" %>>Inactive</option>
                </select>
              <% elsif field.downcase.include?("upload") || field.downcase.include?("file") %>
                <% upload_accept = field == "Excel Upload" ? "accept=\".csv,.xlsx,.xls\"" : nil %>
                <% upload_accept = "accept=\"image/*\" data-max-size-mb=\"5\"" if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
                <input name="module_record[<%= field_key %>]" type="file" <%= upload_accept&.html_safe %> <%= "required" if form_required && field_value.blank? && !other_target_form %>>
                <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
                  <input type="hidden" name="module_record[geo_latitude]" data-training-geo-latitude value="<%= @record&.data&.[]("geo_latitude") %>">
                  <input type="hidden" name="module_record[geo_longitude]" data-training-geo-longitude value="<%= @record&.data&.[]("geo_longitude") %>">
                <% end %>
                <% if field_value.present? %>
                  <small class="field-hint">Current: <%= field_value %></small>
                <% end %>
              <% elsif @slug == "training-topic-mapping" && field == "Department" %>
                <input name="module_record[<%= field_key %>]" type="text" placeholder="Enter <%= resource_person_label(field) %>" value="<%= field_value %>">
              <% elsif module_select_field?(field) %>
                <% options = (module_field_options(field) + static_field_options(field)).compact_blank.uniq %>
                <% options << field_value if field_value.present? && !options.include?(field_value) %>
                <% role_dependency_attr =
                  case field
                  when "Stakeholder Category"
                    "data-role-stakeholder-select"
                  when "Stakeholder Role"
                    "data-stakeholder-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Role"
                    "data-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "User Management Role"
                    "data-user-management-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if ["role-management", "role-name", "user-management-role", "person-type"].include?(@slug) %>
                <% location_dependency_attr = "data-location-level=\"#{field.parameterize}\" data-selected-value=\"#{ERB::Util.html_escape(field_value)}\"" if location_fields.include?(field) %>
                <% training_target_attr =
                  case field
                  when "Month"
                    "data-training-target-month data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "ICS / Block"
                    "data-training-target-ics data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Gram Name"
                    "data-training-target-village data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Main Activity Type"
                    "data-training-main-activity-type data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Main Activity"
                    "data-training-main-activity data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Sub Activity"
                    "data-training-sub-activity data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if @slug == "training-form" %>
                <% seed_target_attr =
                  case field
                  when "Month"
                    "data-seed-target-month data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "ICS"
                    "data-seed-target-ics data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Village"
                    "data-seed-target-village data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Jeevika Jankar Name"
                    "data-seed-target-vrp data-selected-value=\"#{ERB::Util.html_escape(@record&.data&.[]('jeevika_jankar_id').presence || field_value)}\""
                  when "Main Activity"
                    "data-seed-target-topic data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Sub Activity"
                    "data-seed-target-subject data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if other_target_form %>
                <% parent_office_dependency_attr =
                  case field
                  when "Stakeholder Category"
                    "data-parent-office-stakeholder-select"
                  when "Parent Office Type"
                    "data-parent-office-type-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Parent Office"
                    "data-parent-office-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if @slug == "parent-office-add" %>
                <select name="module_record[<%= field_key %>]" <%= role_dependency_attr&.html_safe %> <%= location_dependency_attr&.html_safe %> <%= training_target_attr&.html_safe %> <%= seed_target_attr&.html_safe %> <%= parent_office_dependency_attr&.html_safe %> <%= required_attr %>>
                  <option value=""><%= options.any? ? "Select #{resource_person_label(field)}" : "No #{resource_person_label(field)} saved yet" %></option>
                  <% options.each do |option| %>
                    <option value="<%= option %>" <%= "selected" if option == field_value %>><%= option %></option>
                  <% end %>
                </select>
              <% elsif field.downcase.include?("remarks") || field.downcase.include?("address") %>
                <textarea name="module_record[<%= field_key %>]" rows="3" placeholder="Enter <%= field %>" <%= required_attr %>><%= field_value %></textarea>
              <% elsif field.downcase.include?("password") %>
                <input name="module_record[<%= field_key %>]" type="password" placeholder="Enter <%= field %>" value="<%= field_value %>" <%= required_attr %>>
              <% elsif field.downcase.include?("date") %>
                <input name="module_record[<%= field_key %>]" type="date" value="<%= field_value %>" <%= required_attr %>>
              <% elsif @slug == "training-form" && ["Farmer Count", "Male Count", "Female Count"].include?(field) %>
                <input name="module_record[<%= field_key %>]" type="number" min="0" step="1" placeholder="Enter <%= resource_person_label(field) %>" value="<%= field_value %>" <%= required_attr %> <%= "readonly" if field == "Farmer Count" %> <%= "data-training-farmer-count-input" if field == "Farmer Count" %>>
              <% elsif seed_target_form && field == "Farmer Count" %>
                <input name="module_record[<%= field_key %>]" type="number" min="0" step="1" placeholder="Selected Farmer Count" value="<%= field_value %>" data-seed-farmer-count-input readonly required>
              <% elsif other_target_form && field == "Contact Number" %>
                <input name="module_record[<%= field_key %>]" type="tel" pattern="[0-9]{10}" maxlength="10" placeholder="Auto-filled Contact Number" value="<%= field_value %>" data-seed-vrp-contact readonly required>
              <% elsif other_target_form && field == "Department" %>
                <input name="module_record[<%= field_key %>]" type="text" placeholder="Auto-filled Department" value="<%= field_value %>" data-seed-vrp-department readonly>
              <% elsif other_target_form && field == "Target" %>
                <input name="module_record[<%= field_key %>]" type="number" min="0" step="any" placeholder="Mapped target" value="<%= field_value %>" data-seed-target-quantity readonly required>
              <% elsif other_target_form && field == "Achievement" %>
                <input name="module_record[<%= field_key %>]" type="number" min="0" step="any" placeholder="Enter Achievement" value="<%= field_value %>" data-seed-achievement required>
              <% else %>
                <input name="module_record[<%= field_key %>]" type="text" placeholder="Enter <%= resource_person_label(field) %>" value="<%= field_value %>" <%= "readonly" if @slug == "training-form" && ["Trainee Department", "Trainer Name", "Trainer Contact"].include?(field) && current_app_user&.dig("record_type").to_s == "Vrp" %> <%= "data-user-management-role-input" if @slug == "role-management" && field == "User Management Role" %> <%= required_attr %>>
              <% end %>
            </label>
            <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
              <div class="training-farmer-panel" data-training-farmer-panel data-selected-farmer-ids="<%= json_escape((selected_training_farmer_ids || []).to_json) %>">
                <div class="target-mapping-toolbar">
                  <strong>Target Farmers</strong>
                  <label class="training-select-all">
                    <input type="checkbox" data-training-farmer-select-all>
                    <span>Select all</span>
                  </label>
                  <button type="button" class="list-btn active training-select-all-button" data-training-farmer-select-all-button>Select all</button>
                  <span data-training-farmer-count>0 farmer selected</span>
                </div>
                <div class="vrp-ics-farmer-list" data-training-farmer-list>
                  Select Village Name to load target farmers.
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <% if seed_target_form %>
          <div class="training-farmer-panel" data-seed-farmer-panel data-selected-farmer-ids="<%= json_escape((selected_seed_target_farmer_ids || []).to_json) %>">
            <div class="target-mapping-toolbar">
              <strong>Mapped Farmers</strong>
              <label class="training-select-all">
                <input type="checkbox" data-seed-farmer-select-all>
                <span>Select all</span>
              </label>
              <button type="button" class="list-btn active training-select-all-button" data-seed-farmer-select-all-button>Select all</button>
              <span data-seed-farmer-count>0 farmer selected</span>
            </div>
            <div class="list-search compact seed-farmer-search">
              <span>⌕</span>
              <input type="search" placeholder="Search mapped farmers" data-seed-farmer-search>
            </div>
            <div class="training-empty-state" data-seed-farmer-search-empty hidden>No mapped farmers matched your search.</div>
            <div class="vrp-ics-farmer-list" data-seed-farmer-list>
              Select Village and Activity to load mapped farmers.
            </div>
          </div>
        <% end %>

        <div class="module-form-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update" : "Save" %></button>
        </div>
      <% end %>
    </section>

    <% unless @slug == "new-user" || entry_only_slugs.include?(@slug) || other_target_form %>
      <% saved_record_fields = @module[:fields].reject { |field| field == "Status" } %>
      <% full_saved_record_slugs = ["state-master", "district-master", "block-master", "gram-panchayat-master", "village-master", "person-type"] %>
      <% saved_record_fields = saved_record_fields.first(4) unless full_saved_record_slugs.include?(@slug) %>
      <section class="module-card">
        <div class="module-card-header">
          <h2>Saved Records</h2>
          <span class="record-count"><%= @records.size %> records</span>
        </div>
        <div class="list-controls">
          <div class="list-search">
            <span>⌕</span>
            <input type="search" placeholder="Search records" data-table-search="module_saved_records">
          </div>
          <%= form_with url: import_module_path(@slug), method: :post, multipart: true, local: true, class: "list-control-actions" do |form| %>
            <label class="import-btn">
              Choose Excel
              <%= form.file_field :file, accept: ".csv,.xlsx", data: { import_file: true }, hidden: true %>
            </label>
            <%= form.submit "Upload", class: "list-btn upload" %>
            <%= link_to "Export", export_module_path(@slug, format: :csv), class: "list-btn export" %>
          <% end %>
        </div>
        <div class="table-shell">
          <table class="module-table" id="module_saved_records" data-paginated-table data-page-size="15">
            <thead>
              <tr>
                <% saved_record_fields.each do |field| %>
                  <th><%= resource_person_label(field) %></th>
                <% end %>
                <th>Saved At</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @records.any? %>
                <% @records.each do |record| %>
                  <tr>
                    <% saved_record_fields.each do |field| %>
                      <td><%= module_record_field_value(record, field).presence || "-" %></td>
                    <% end %>
                    <td><%= record.created_at&.strftime("%d-%m-%Y %I:%M %p") %></td>
                    <td><span class="status-pill <%= record.data["status"] == "Inactive" ? "inactive" : "active" %>"><%= record.data["status"].presence || "Active" %></span></td>
                    <td>
                      <div class="table-actions">
                        <%= link_to "Edit", edit_module_record_path(@slug, record), class: "table-action" %>
                        <%= button_to(record.data["status"] == "Inactive" ? "Activate" : "Deactivate", toggle_module_record_path(@slug, record), method: :patch, class: "table-action") %>
                        <%= button_to "Delete", module_record_path(@slug, record), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this record?" } } %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="<%= saved_record_fields.size + 3 %>">No records saved yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="table-pagination" data-pagination-for="module_saved_records"></div>
      </section>
    <% end %>
  </div>
  <% end %>

  <% if @module[:features].present? %>
    <div class="module-grid">
      <% if @module[:features].present? %>
        <section class="module-card">
          <div class="module-card-header">
            <h2>Features</h2>
          </div>
          <div class="chip-list">
            <% @module[:features].each do |feature| %>
              <span><%= feature %></span>
            <% end %>
          </div>
        </section>
      <% end %>

    </div>
  <% end %>
</section>
