<% content_for :title, @module[:title] %>

<section class="module-page">
  <% hide_module_hero = @slug == "jeevika-jankar-bill-list" && @bill_print_mode %>
  <% unless hide_module_hero %>
    <div class="module-hero">
      <div>
        <p class="vrp-eyebrow"><%= @module[:group] %></p>
        <h1><%= @slug == "new-user" ? "Registration" : @module[:title] %></h1>
        <p><%= @module[:purpose] %></p>
      </div>
    </div>
  <% end %>

  <% list_only_slugs = ["activity-group-list", "vrp-activity-list", "task-completion-indicator-list", "approval-list", "access-control-list", "vrp-bill-list", "jeevika-jankar-bill-list", "training-form-list", "seed-distribution-target-list", "papl360-target-list"] %>
  <% entry_only_slugs = ["add-activity-group", "add-vrp-activity", "task-completion-indicator", "approval-master", "access-control", "vrp-bill-add", "jeevika-jankar-bill-process", "training-form"] %>

  <% if @slug == "jeevika-jankar-bill-list" && (@bill_print_mode || @bill_detail_record.present?) %>
    <% detail_record = @record || @bill_detail_record %>
    <% detail_items = jeevika_bill_detail_rows(detail_record) %>
    <% detail_summary = jeevika_bill_summary(detail_record) %>
    <% stakeholder_profile = current_stakeholder_profile %>
    <% vrp_photo = jeevika_bill_attachment_rows(detail_record).first&.last %>
    <% money = ->(value) { number_to_currency(value.to_f, unit: "₹", delimiter: ",", precision: 2) } %>
    <% if @bill_print_mode %>
      <% bill_vrp = jeevika_bill_vrp(detail_record) %>
      <% prepared_by = jeevika_bill_prepared_by(detail_record) %>
      <% approved_rows = jeevika_bill_approved_by_rows(detail_record) %>
      <section class="bill-print-sheet">
        <div class="bill-print-header">
          <div>
            <%= image_tag app_logo_path, alt: app_display_name, class: "bill-print-logo" %>
          </div>
          <div class="bill-print-stakeholder">
            <strong><%= app_display_name %></strong>
            <span><%= stakeholder_profile&.data&.[]("full_address").presence || "-" %></span>
            <span>Phone: <%= stakeholder_profile&.data&.[]("phone_number").presence || "-" %></span>
            <span>Email: <%= stakeholder_profile&.data&.[]("email").presence || "-" %></span>
          </div>
        </div>

        <div class="bill-print-profile-row">
          <div class="bill-print-vrp-block">
            <% if vrp_photo&.attached? %>
              <%= image_tag rails_blob_path(vrp_photo, only_path: true), alt: "VRP Photo", class: "bill-print-vrp-photo" %>
            <% end %>
            <p>
              <strong><%= jeevika_jankar_display_name(detail_record.data["select_vrp_name"].presence || jeevika_jankar_vrp_label(detail_record.data["select_vrp"])).presence || "-" %></strong>(VRP)<br>
              Block: <%= (bill_vrp&.vrp_profile&.block_id).presence || "-" %><br>
              Mobile No.: <%= bill_vrp&.mobile_no.presence || "-" %>
            </p>
          </div>
          <div class="bill-print-meta">
            <p>VRP Bill ID: #<%= detail_record.id %></p>
            <p>Invoice Date: <%= bill_display_date(detail_record.data["invoice_date"].presence || detail_record.created_at) %></p>
            <p>Invoice Month: <%= detail_record.data["bill_month"].presence || "-" %></p>
            <p><%= detail_summary[:fco].presence || "-" %> - FCO, <%= detail_summary[:to].presence || "-" %> - TO</p>
            <p>Project: <%= detail_summary[:projects].presence || "-" %></p>
          </div>
        </div>

        <h3 class="bill-print-section-title">Time Slot</h3>
        <table class="bill-print-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Working Date</th>
              <th>Village Name</th>
              <th>Activity</th>
              <th>TCI Name</th>
              <th>Number</th>
            </tr>
          </thead>
          <tbody>
            <% jeevika_bill_time_slot_rows(detail_record).each_with_index do |row, index| %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= row[:working_date] %></td>
                <td><%= row[:village] %></td>
                <td><%= row[:activity] %></td>
                <td><%= row[:tci] %></td>
                <td><%= row[:number] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <table class="bill-print-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Description</th>
              <th>Rate</th>
              <th>Number</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <% jeevika_bill_description_rows(detail_record).each do |row| %>
              <tr>
                <td><%= row[:index] %></td>
                <td><%= row[:description] %></td>
                <td>Rs.<%= row[:rate] %></td>
                <td><%= row[:number] %></td>
                <td><%= money.call(row[:total]) %></td>
              </tr>
            <% end %>
            <tr>
              <td colspan="4" class="bill-print-total-label">Total Payment</td>
              <td class="bill-print-total-value"><%= money.call(detail_summary[:total_amount]) %></td>
            </tr>
          </tbody>
        </table>

        <table class="bill-print-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Bank Name</th>
              <th>Account Number</th>
              <th>IFSC Code</th>
              <th>Address</th>
            </tr>
          </thead>
          <tbody>
            <% jeevika_bill_bank_rows(detail_record).each_with_index do |row, index| %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= row[:bank_name] %></td>
                <td><%= row[:account_number] %></td>
                <td><%= row[:ifsc_code] %></td>
                <td><%= row[:address] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <div class="bill-print-footer">
          <div class="bill-print-prepared">
            <% if jeevika_bill_status_label(detail_record).to_s.downcase.include?("final approved") %>
              <span class="bill-final-approved">Final Approved</span>
            <% end %>
            <strong>Prepared by</strong>
            <span><%= prepared_by[:name] %>(at: <%= prepared_by[:at] %>)</span>
          </div>
          <div class="bill-print-approved">
            <strong>Verified & Approved By</strong>
            <% if approved_rows.any? %>
              <% approved_rows.each do |level, approver, at, action_by| %>
                <span><%= level %> ==> <%= action_by.presence || approver %> (<%= approver %>) <%= at %></span>
              <% end %>
            <% else %>
              <span>-</span>
            <% end %>
          </div>
        </div>
      </section>
    <% else %>
    <section class="module-card jeevika-bill-detail-card <%= "print-bill-card" if @bill_print_mode %>">
      <% if @bill_print_mode %>
        <div class="bill-print-header">
          <div>
            <%= image_tag app_logo_path, alt: app_display_name, class: "bill-print-logo" %>
          </div>
          <div class="bill-print-stakeholder">
            <strong><%= app_display_name %></strong>
            <span><%= stakeholder_profile&.data&.[]("full_address").presence || "-" %></span>
            <span>Phone: <%= stakeholder_profile&.data&.[]("phone_number").presence || "-" %></span>
            <span>Email: <%= stakeholder_profile&.data&.[]("email").presence || "-" %></span>
          </div>
        </div>
        <% if vrp_photo&.attached? %>
          <%= image_tag rails_blob_path(vrp_photo, only_path: true), alt: "VRP Photo", class: "bill-print-vrp-photo" %>
        <% end %>
      <% end %>
      <div class="module-card-header list-title-header">
        <h2>Jeevika Jankar Bill Details</h2>
        <div class="list-control-actions no-print">
          <%= link_to "Back", module_path("jeevika-jankar-bill-list"), class: "list-btn" %>
          <button type="button" class="list-btn export" onclick="window.print()">Print</button>
        </div>
      </div>

      <div class="bill-detail-summary">
        <div>
          <strong>TO</strong>
          <span><%= detail_summary[:to].presence || "-" %></span>
        </div>
        <div>
          <strong>FCO</strong>
          <span><%= detail_summary[:fco].presence || "-" %></span>
        </div>
        <div>
          <strong>Bill ID</strong>
          <span><%= detail_record.id %></span>
        </div>
        <div>
          <strong>VRP</strong>
          <span><%= jeevika_jankar_display_name(detail_record.data["select_vrp_name"].presence || jeevika_jankar_vrp_label(detail_record.data["select_vrp"])).presence || "-" %></span>
        </div>
        <div>
          <strong>Financial Year</strong>
          <span><%= detail_record.data["financial_year"].presence || "-" %></span>
        </div>
        <div>
          <strong>Bill Month</strong>
          <span><%= detail_record.data["bill_month"].presence || "-" %></span>
        </div>
        <div>
          <strong>Projects</strong>
          <span><%= detail_summary[:projects].presence || "-" %></span>
        </div>
        <div>
          <strong>Activity Groups</strong>
          <span><%= detail_summary[:activity_groups].presence || "-" %></span>
        </div>
        <div>
          <strong>Total Amount</strong>
          <span><%= money.call(detail_summary[:total_amount]) %></span>
        </div>
        <div>
          <strong>Remarks</strong>
          <span><%= detail_record.data["remarks"].presence || "-" %></span>
        </div>
        <div>
          <strong>Deduction Amount</strong>
          <span><%= detail_summary[:deduction_amount].present? ? money.call(detail_summary[:deduction_amount]) : "-" %></span>
        </div>
        <div>
          <strong>Total Payable</strong>
          <span><%= money.call(detail_summary[:total_payable]) %></span>
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table detail-table">
          <thead>
            <tr>
              <th>Sl No.</th>
              <th>ICS</th>
              <th>Village</th>
              <th>Main Activity</th>
              <th>Sub Activity</th>
              <th>Target</th>
              <th>Achievement</th>
              <th>Pending</th>
              <th>Rate</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <% detail_items.each_with_index do |item, index| %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= item["ics"].presence || "-" %></td>
                <td><%= item["village"].presence || "-" %></td>
                <td><%= item["main_activity"].presence || "-" %></td>
                <td><%= item["activity"].presence || "-" %></td>
                <td><%= item["target_quantity"].presence || "0" %></td>
                <td><%= item["achievement_count"].presence || "0" %></td>
                <td><%= item["pending_count"].presence || "0" %></td>
                <td><%= item["rate"].presence || "0.00" %></td>
                <td><%= item["amount"].presence || "0.00" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="table-shell">
        <table class="module-table detail-table">
          <thead>
            <tr>
              <th>Farmer</th>
              <th>Mobile</th>
              <th>Village</th>
              <th>Main Activity</th>
              <th>Sub Activity</th>
              <th>Training Date</th>
            </tr>
          </thead>
          <tbody>
            <% farmer_rows = detail_items.flat_map { |item| Array(item["farmer_details"]).map { |farmer| farmer.merge("village" => item["village"], "main_activity" => item["main_activity"], "activity" => item["activity"]) } } %>
            <% if farmer_rows.any? %>
              <% farmer_rows.each do |farmer| %>
                <tr>
                  <td><%= farmer["name"].presence || "-" %></td>
                  <td><%= farmer["mobile_no"].presence || "-" %></td>
                  <td><%= farmer["village"].presence || "-" %></td>
                  <td><%= farmer["training_topic"].presence || farmer["main_activity"].presence || "-" %></td>
                  <td><%= farmer["training_subject"].presence || farmer["activity"].presence || "-" %></td>
                  <td><%= farmer["training_date"].presence || "-" %></td>
                </tr>
              <% end %>
            <% else %>
              <tr><td colspan="6">No farmer details saved for this bill.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="table-shell no-print">
        <table class="module-table attachment-table">
          <thead>
            <tr>
              <th>Document</th>
              <th>Preview</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% jeevika_bill_attachment_rows(detail_record).each do |label, attachment| %>
              <tr>
                <td><%= label %></td>
                <td>
                  <% if attachment&.attached? %>
                    <%= image_tag rails_blob_path(attachment, only_path: true), alt: label, class: "attachment-thumb" %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td>
                  <% if attachment&.attached? %>
                    <%= link_to "View", rails_blob_path(attachment, disposition: "inline"), target: "_blank", class: "list-btn active attachment-view" %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% approval_status_text = jeevika_bill_status_label(detail_record).to_s.downcase %>
      <% show_approval_progress = !approval_status_text.include?("submitted") || jeevika_bill_approval_history(detail_record).any? %>
      <% if show_approval_progress %>
      <div class="approval-progress-section no-print">
        <h2>Jeevika Jankar Bill Approval Progress</h2>
        <div class="approval-progress-grid">
          <% jeevika_bill_approval_steps(detail_record).each do |step| %>
            <% step_history = jeevika_bill_approval_history(detail_record).find { |history| approval_sequence_from_level(history.data["approval_level"]) == approval_sequence_from_level(step.data["approval_level"]) && ["Approved", "Rejected", "Returned"].include?(history.data["action"]) } %>
            <% closing_action = step_history&.data&.[]("action") %>
            <% state = ["Rejected", "Returned"].include?(closing_action) ? "rejected" : (step_history ? "approved" : (jeevika_bill_current_approval_step(detail_record)&.id == step.id ? "current" : "pending")) %>
            <div class="approval-progress-card <%= state %>">
              <div class="approval-progress-icon"><%= state == "approved" ? "✓" : (closing_action == "Returned" ? "↩" : (state == "rejected" ? "×" : "•")) %></div>
              <h3><%= step.data["approval_level"] %></h3>
              <p><%= step.data["approver_approved_by"].presence || "-" %></p>
              <% if step_history %>
                <small><%= step_history.data["action"] %> at <%= step_history.data["action_at"] %></small>
                <% if step_history.data["remarks"].present? %>
                  <p><strong>Remarks:</strong> <%= step_history.data["remarks"] %></p>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if jeevika_bill_current_approver?(detail_record) && jeevika_bill_status_label(detail_record).include?("Pending") %>
          <div class="module-form-actions">
            <button type="button" class="list-btn active" data-open-approval-modal data-approval-action="approve" data-approval-url="<%= approve_bill_module_record_path("jeevika-jankar-bill-list", detail_record) %>">Approve</button>
            <button type="button" class="list-btn deactive" data-open-approval-modal data-approval-action="reject" data-approval-url="<%= reject_bill_module_record_path("jeevika-jankar-bill-list", detail_record) %>">Reject</button>
          </div>
        <% end %>
      </div>
      <% end %>

      <% if jeevika_bill_current_approver?(detail_record) && jeevika_bill_status_label(detail_record).include?("Pending") %>
        <dialog class="approval-remarks-modal" data-approval-modal>
          <%= form_with url: approve_bill_module_record_path("jeevika-jankar-bill-list", detail_record), method: :patch, class: "approval-modal-form", data: { approval_modal_form: true } do %>
            <div class="approval-modal-header">
              <h2 data-approval-modal-title>Approval Remarks</h2>
              <button type="button" data-close-approval-modal aria-label="Close">×</button>
            </div>
            <label for="bill_approval_modal_remarks">Remarks</label>
            <textarea id="bill_approval_modal_remarks" name="remarks" rows="4" placeholder="Enter remarks" required></textarea>
            <div class="approval-modal-actions">
              <button type="button" class="table-action" data-close-approval-modal>Cancel</button>
              <button type="submit" class="list-btn active" data-approval-modal-submit>Submit</button>
            </div>
          <% end %>
        </dialog>
      <% end %>
    </section>
    <% end %>

  <% elsif @slug == "approval-master" %>
    <% module_options = static_field_options("Module Name") %>
    <% stakeholder_options = module_field_options("Stakeholder Name") %>
    <% approver_options = module_field_options("Approver (Approved By)") %>
    <% selected_module_name = @record&.data&.[]("module_name").to_s %>
    <% selected_stakeholder_name = @record&.data&.[]("stakeholder_name").to_s %>
    <% selected_user_name = @record&.data&.[]("user_name").to_s %>
    <% selected_status = @record&.data&.[]("status").presence || "Active" %>
    <%
      approval_channel_records = Array(@approval_channel_records.presence || (@record.present? ? [@record] : []))
      approval_rows = approval_channel_records
        .sort_by { |record| approval_sequence_from_level(record.data["approval_level"]) }
        .map do |record|
          sequence = approval_sequence_from_level(record.data["approval_level"])
          {
            level: approval_level_label_for_sequence(sequence),
            sequence: sequence,
            approver: record.data["approver_approved_by"].to_s
          }
        end
      approval_rows = (1..3).map { |number| { level: approval_level_label_for_sequence(number), sequence: number, approver: "" } } if approval_rows.blank?
      next_approval_level = approval_rows.map { |row| row[:sequence].to_i }.max.to_i + 1
    %>
    <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
    <% form_method = @record.present? ? :patch : :post %>
    <section class="module-card approval-channel-card">
      <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form", data: { user_role_form: true } } do %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Module Name <em>*</em></span>
            <select name="module_record[module_name]" required>
              <option value="">Select Module</option>
              <% module_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if option == selected_module_name %>><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Stakeholder Category <em>*</em></span>
            <select name="module_record[stakeholder_name]" required data-role-stakeholder-select>
              <option value="">Select Stakeholder Category</option>
              <% stakeholder_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if option == selected_stakeholder_name %>><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>User Name <em>*</em></span>
            <select name="module_record[user_name]" required data-office-user-select>
              <option value="">Select User Name</option>
              <% approver_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if option == selected_user_name %>><%= option %></option>
              <% end %>
            </select>
          </label>
        </div>

        <div class="approval-levels" data-approval-levels data-next-approval-level="<%= next_approval_level %>">
          <div class="approval-level-toolbar">
            <h2>Approval Levels</h2>
            <button type="button" class="add-level-btn" data-add-approval-level>Add More</button>
          </div>
          <div class="approval-level-table" data-approval-level-table>
            <div class="approval-level-head">Level</div>
            <div class="approval-level-head">Approval User</div>
            <div class="approval-level-head">Action</div>

            <% approval_rows.each do |row| %>
              <div class="approval-level-cell" data-approval-row="<%= row[:sequence] %>">
                <strong><%= row[:level] %></strong>
                <small>Approval step <%= row[:sequence] %></small>
              </div>
              <div class="approval-level-cell" data-approval-row="<%= row[:sequence] %>">
                <select name="module_record[approval_steps][<%= row[:level] %>]">
                  <option value="">Select approval user</option>
                  <% approver_options.each do |option| %>
                    <option value="<%= option %>" <%= "selected" if option == row[:approver] %>><%= option %></option>
                  <% end %>
                </select>
                <small>Select the user responsible at this approval stage.</small>
              </div>
              <div class="approval-level-cell" data-approval-row="<%= row[:sequence] %>">
                <button type="button" class="remove-level-btn" data-remove-approval-level>Remove</button>
              </div>
            <% end %>
          </div>
        </div>

        <input type="hidden" name="module_record[status]" value="<%= selected_status %>">

        <div class="module-form-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update" : "Save" %></button>
        </div>
      <% end %>
    </section>
  <% elsif @slug == "user-hierarchy-mapping" %>
    <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
    <% form_method = @record.present? ? :patch : :post %>
    <% stakeholder_options = module_field_options("Stakeholder Category") %>
    <% user_options = module_field_options("Level 1 User") %>
    <%
      collapse_hierarchy_users = lambda do |*values|
        values.flatten.flat_map do |value|
          value.to_s.split(";").flat_map do |segment|
            user_segment = segment.include?("->") ? segment.split("->", 2).last : segment
            user_segment.to_s.split(",")
          end
        end.map(&:strip).compact_blank.uniq
      end
    %>
    <% selected_stakeholder = @record&.data&.[]("stakeholder_category").to_s %>
    <% selected_level_1 = @record&.data&.[]("level_1_user").to_s %>
    <% raw_level_2_mappings = @record&.data&.[]("level_2_mappings") %>
    <% raw_level_2_mappings = raw_level_2_mappings.values if raw_level_2_mappings.is_a?(Hash) %>
    <% selected_level_2_users = Array(raw_level_2_mappings).flat_map do |mapping| %>
      <% next unless mapping.respond_to?(:[]) %>
      <% collapse_hierarchy_users.call(mapping["level_2_user"], mapping["level_3_users"]) %>
    <% end %>
    <% selected_level_2_users = selected_level_2_users.compact_blank.uniq %>
    <% if selected_level_2_users.blank? %>
      <% selected_level_2_users = collapse_hierarchy_users.call(@record&.data&.[]("level_2_users").presence || @record&.data&.[]("level_2_user"), @record&.data&.[]("level_3_users").presence || @record&.data&.[]("level_3_user")) %>
    <% end %>
    <% selected_level_2_users = [""] if selected_level_2_users.blank? %>
    <div class="module-grid">
      <section class="module-card approval-channel-card">
        <div class="module-card-header">
          <h2><%= @record.present? ? "Edit Mapping" : "Fields" %></h2>
        </div>
        <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form" } do %>
          <div class="module-form-grid user-registration-grid">
            <label>
              <span>Stakeholder Category</span>
              <select name="module_record[stakeholder_category]">
                <option value=""><%= stakeholder_options.any? ? "Select Stakeholder Category" : "No Stakeholder Category saved yet" %></option>
                <% stakeholder_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if option == selected_stakeholder %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Head</span>
              <select name="module_record[level_1_user]">
                <option value=""><%= user_options.any? ? "Select Head" : "No user saved yet" %></option>
                <% user_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if option == selected_level_1 %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Status</span>
              <% status_value = @record&.data&.[]("status").presence || "Active" %>
              <select name="module_record[status]">
                <option <%= "selected" if status_value == "Active" %>>Active</option>
                <option <%= "selected" if status_value == "Inactive" %>>Inactive</option>
              </select>
            </label>
          </div>

          <div class="approval-levels user-hierarchy-levels" data-user-hierarchy-levels data-next-user-row="<%= selected_level_2_users.size + 1 %>">
            <div class="approval-level-toolbar">
              <h2>Subordinates</h2>
              <button type="button" class="add-level-btn" data-add-user-row>Add Subordinates</button>
            </div>
            <div class="approval-level-table user-hierarchy-table" data-user-hierarchy-table>
              <div class="approval-level-head">Level</div>
              <div class="approval-level-head">Subordinates</div>
              <div class="approval-level-head">Action</div>

              <% selected_level_2_users.each_with_index do |selected_level_2_user, index| %>
                <% row_number = index + 1 %>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <strong>Level 2</strong>
                  <small>User <%= row_number %></small>
                </div>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <select name="module_record[level_2_mappings][<%= row_number %>][level_2_user]">
                    <option value=""><%= user_options.any? ? "Select Subordinates" : "No user saved yet" %></option>
                    <% user_options.each do |option| %>
                      <option value="<%= option %>" <%= "selected" if option == selected_level_2_user %>><%= option %></option>
                    <% end %>
                  </select>
                </div>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <button type="button" class="remove-level-btn" data-remove-user-row>Remove</button>
                </div>
              <% end %>
            </div>
          </div>

          <div class="module-form-actions">
            <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
            <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update" : "Save" %></button>
          </div>
        <% end %>
      </section>

      <section class="module-card">
        <div class="module-card-header">
          <h2>Saved Records</h2>
          <span class="record-count"><%= @records.size %> records</span>
        </div>
        <div class="table-shell">
          <table class="module-table" id="module_saved_records" data-paginated-table data-page-size="15">
            <thead>
              <tr>
                <th>Stakeholder Category</th>
                <th>Head</th>
                <th>Subordinates</th>
                <th>Saved At</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @records.any? %>
                <% @records.each do |record| %>
                  <% record_level_2_mappings = record.data["level_2_mappings"] %>
                  <% record_level_2_mappings = record_level_2_mappings.values if record_level_2_mappings.is_a?(Hash) %>
                  <% mapped_level_2_users = Array(record_level_2_mappings).flat_map { |mapping| mapping.respond_to?(:[]) ? collapse_hierarchy_users.call(mapping["level_2_user"], mapping["level_3_users"]) : [] }.compact_blank.uniq %>
                  <% fallback_level_2_users = collapse_hierarchy_users.call(record.data["level_2_users"].presence || record.data["level_2_user"], record.data["level_3_users"].presence || record.data["level_3_user"]) %>
                  <tr>
                    <td><%= record.data["stakeholder_category"].presence || "-" %></td>
                    <td><%= record.data["level_1_user"].presence || "-" %></td>
                    <td><%= mapped_level_2_users.join(", ").presence || fallback_level_2_users.join(", ").presence || "-" %></td>
                    <td><%= record.created_at&.strftime("%d-%m-%Y %I:%M %p") %></td>
                    <td><span class="status-pill <%= record.data["status"] == "Inactive" ? "inactive" : "active" %>"><%= record.data["status"].presence || "Active" %></span></td>
                    <td>
                      <div class="table-actions">
                        <%= link_to "Edit", edit_module_record_path(@slug, record), class: "table-action" %>
                        <%= button_to(record.data["status"] == "Inactive" ? "Activate" : "Deactivate", toggle_module_record_path(@slug, record), method: :patch, class: "table-action") %>
                        <%= button_to "Delete", module_record_path(@slug, record), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this record?" } } %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7">No records saved yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="table-pagination" data-pagination-for="module_saved_records"></div>
      </section>
    </div>
