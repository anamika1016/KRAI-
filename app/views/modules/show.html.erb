<% content_for :title, @module[:title] %>

<section class="module-page">
  <div class="module-hero">
    <div>
      <p class="vrp-eyebrow"><%= @module[:group] %></p>
      <h1><%= @slug == "new-user" ? "Registration" : @module[:title] %></h1>
      <p><%= @module[:purpose] %></p>
    </div>
  </div>

  <% list_only_slugs = ["activity-group-list", "vrp-activity-list", "task-completion-indicator-list", "approval-list", "access-control-list", "vrp-bill-list", "training-form-list"] %>
  <% entry_only_slugs = ["add-activity-group", "add-vrp-activity", "task-completion-indicator", "approval-master", "access-control", "vrp-bill-add", "training-form"] %>

  <% if @slug == "approval-master" && @record.blank? %>
    <% module_options = static_field_options("Module Name") %>
    <% stakeholder_options = module_field_options("Stakeholder Name") %>
    <% approver_options = module_field_options("Approver (Approved By)") %>
    <% approval_levels = (1..3).map { |number| "Approval #{number}" } %>
    <section class="module-card approval-channel-card">
      <%= form_with url: records_module_path(@slug), method: :post, html: { class: "module-entry-form", data: { user_role_form: true, approval_office_cascade: true, office_map: json_escape(office_category_mappings.to_json), office_user_map: json_escape(approval_user_mappings.to_json) } } do %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Module Name <em>*</em></span>
            <select name="module_record[module_name]" required>
              <option value="">Select Module</option>
              <% module_options.each do |option| %>
                <option value="<%= option %>"><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Stakeholder Category <em>*</em></span>
            <select name="module_record[stakeholder_name]" required data-role-stakeholder-select>
              <option value="">Select Stakeholder Category</option>
              <% stakeholder_options.each do |option| %>
                <option value="<%= option %>"><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Office Category <em>*</em></span>
            <select name="module_record[office_category]" required data-office-category-select data-selected-value="">
              <option value="">Select Office Category</option>
            </select>
          </label>

          <label>
            <span>Office Name <em>*</em></span>
            <select name="module_record[office_name]" required data-office-name-select data-selected-value="">
              <option value="">Select Office Name</option>
            </select>
          </label>

          <label>
            <span>User Name <em>*</em></span>
            <select name="module_record[user_name]" required data-office-user-select>
              <option value="">Select User Name</option>
            </select>
          </label>
        </div>

        <div class="approval-levels" data-approval-levels data-next-approval-level="<%= approval_levels.size + 1 %>">
          <div class="approval-level-toolbar">
            <h2>Approval Levels</h2>
            <button type="button" class="add-level-btn" data-add-approval-level>Add More</button>
          </div>
          <div class="approval-level-table" data-approval-level-table>
            <div class="approval-level-head">Level</div>
            <div class="approval-level-head">Approval User</div>
            <div class="approval-level-head">Action</div>

            <% approval_levels.each_with_index do |level, index| %>
              <div class="approval-level-cell" data-approval-row="<%= index + 1 %>">
                <strong><%= level %></strong>
                <small>Approval step <%= index + 1 %></small>
              </div>
              <div class="approval-level-cell" data-approval-row="<%= index + 1 %>">
                <select name="module_record[approval_steps][<%= level %>]">
                  <option value="">Select approval user</option>
                  <% approver_options.each do |option| %>
                    <option value="<%= option %>"><%= option %></option>
                  <% end %>
                </select>
                <small>Select the user responsible at this approval stage.</small>
              </div>
              <div class="approval-level-cell" data-approval-row="<%= index + 1 %>">
                <button type="button" class="remove-level-btn" data-remove-approval-level>Remove</button>
              </div>
            <% end %>
          </div>
        </div>

        <input type="hidden" name="module_record[status]" value="Active">

        <div class="module-form-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      <% end %>
    </section>
  <% elsif @slug == "user-hierarchy-mapping" %>
    <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
    <% form_method = @record.present? ? :patch : :post %>
    <% stakeholder_options = module_field_options("Stakeholder Category") %>
    <% user_options = module_field_options("Level 1 User") %>
    <% selected_stakeholder = @record&.data&.[]("stakeholder_category").to_s %>
    <% selected_level_1 = @record&.data&.[]("level_1_user").to_s %>
    <% raw_level_2_mappings = @record&.data&.[]("level_2_mappings") %>
    <% raw_level_2_mappings = raw_level_2_mappings.values if raw_level_2_mappings.is_a?(Hash) %>
    <% selected_level_2_mappings = Array(raw_level_2_mappings).filter_map do |mapping| %>
      <% next unless mapping.respond_to?(:[]) %>
      <% level_2_user = mapping["level_2_user"].to_s %>
      <% level_3_users = Array(mapping["level_3_users"]).flat_map { |value| value.to_s.split(",") }.map(&:strip).compact_blank %>
      <% { "level_2_user" => level_2_user, "level_3_users" => level_3_users.presence || [""] } %>
    <% end %>
    <% if selected_level_2_mappings.blank? %>
      <% legacy_level_2_users = Array(@record&.data&.[]("level_2_users").presence || @record&.data&.[]("level_2_user")).flat_map { |value| value.to_s.split(",") }.map(&:strip).compact_blank %>
      <% selected_level_2_mappings = legacy_level_2_users.map { |user| { "level_2_user" => user, "level_3_users" => [""] } } %>
    <% end %>
    <% selected_level_2_mappings = [{ "level_2_user" => "", "level_3_users" => [""] }] if selected_level_2_mappings.blank? %>
    <div class="module-grid">
      <section class="module-card approval-channel-card">
        <div class="module-card-header">
          <h2><%= @record.present? ? "Edit Mapping" : "Fields" %></h2>
        </div>
        <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form" } do %>
          <div class="module-form-grid user-registration-grid">
            <label>
              <span>Stakeholder Category</span>
              <select name="module_record[stakeholder_category]">
                <option value=""><%= stakeholder_options.any? ? "Select Stakeholder Category" : "No Stakeholder Category saved yet" %></option>
                <% stakeholder_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if option == selected_stakeholder %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Level 1 User</span>
              <select name="module_record[level_1_user]">
                <option value=""><%= user_options.any? ? "Select Level 1 User" : "No user saved yet" %></option>
                <% user_options.each do |option| %>
                  <option value="<%= option %>" <%= "selected" if option == selected_level_1 %>><%= option %></option>
                <% end %>
              </select>
            </label>

            <label>
              <span>Status</span>
              <% status_value = @record&.data&.[]("status").presence || "Active" %>
              <select name="module_record[status]">
                <option <%= "selected" if status_value == "Active" %>>Active</option>
                <option <%= "selected" if status_value == "Inactive" %>>Inactive</option>
              </select>
            </label>
          </div>

          <div class="approval-levels user-hierarchy-levels" data-user-hierarchy-levels data-next-user-row="<%= selected_level_2_mappings.size + 1 %>">
            <div class="approval-level-toolbar">
              <h2>Level 2 and Level 3 Users</h2>
              <button type="button" class="add-level-btn" data-add-user-row>Add Level 2</button>
            </div>
            <div class="approval-level-table user-hierarchy-table" data-user-hierarchy-table>
              <div class="approval-level-head">Level</div>
              <div class="approval-level-head">Level 2 User</div>
              <div class="approval-level-head">Level 3 Users</div>
              <div class="approval-level-head">Action</div>

              <% selected_level_2_mappings.each_with_index do |mapping, index| %>
                <% row_number = index + 1 %>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <strong>Level 2</strong>
                  <small>User <%= row_number %></small>
                </div>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <select name="module_record[level_2_mappings][<%= row_number %>][level_2_user]">
                    <option value=""><%= user_options.any? ? "Select Level 2 User" : "No user saved yet" %></option>
                    <% user_options.each do |option| %>
                      <option value="<%= option %>" <%= "selected" if option == mapping["level_2_user"] %>><%= option %></option>
                    <% end %>
                  </select>
                </div>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <div class="level-3-user-list" data-level3-list>
                    <% Array(mapping["level_3_users"]).each do |selected_level_3_user| %>
                      <div class="level-3-user-row" data-level3-row>
                        <select name="module_record[level_2_mappings][<%= row_number %>][level_3_users][]">
                          <option value=""><%= user_options.any? ? "Select Level 3 User" : "No user saved yet" %></option>
                          <% user_options.each do |option| %>
                            <option value="<%= option %>" <%= "selected" if option == selected_level_3_user %>><%= option %></option>
                          <% end %>
                        </select>
                        <button type="button" class="remove-level-btn compact" data-remove-level3-user>Remove</button>
                      </div>
                    <% end %>
                  </div>
                  <button type="button" class="add-level-btn compact" data-add-level3-user>Add Level 3</button>
                </div>
                <div class="approval-level-cell" data-user-row="<%= row_number %>">
                  <button type="button" class="remove-level-btn" data-remove-user-row>Remove</button>
                </div>
              <% end %>
            </div>
          </div>

          <div class="module-form-actions">
            <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
            <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update" : "Save" %></button>
          </div>
        <% end %>
      </section>

      <section class="module-card">
        <div class="module-card-header">
          <h2>Saved Records</h2>
          <span class="record-count"><%= @records.size %> records</span>
        </div>
        <div class="table-shell">
          <table class="module-table" id="module_saved_records" data-paginated-table data-page-size="15">
            <thead>
              <tr>
                <th>Stakeholder Category</th>
                <th>Level 1 User</th>
                <th>Level 2 User</th>
                <th>Level 3 User</th>
                <th>Saved At</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @records.any? %>
                <% @records.each do |record| %>
                  <% record_level_2_mappings = record.data["level_2_mappings"] %>
                  <% record_level_2_mappings = record_level_2_mappings.values if record_level_2_mappings.is_a?(Hash) %>
                  <% record_level_2_mappings = Array(record_level_2_mappings) %>
                  <% level_3_display = record.data["level_3_user"].presence || record_level_2_mappings.filter_map { |mapping| mapping.respond_to?(:[]) && mapping["level_2_user"].present? && Array(mapping["level_3_users"]).compact_blank.any? ? "#{mapping["level_2_user"]} -> #{Array(mapping["level_3_users"]).compact_blank.join(", ")}" : nil }.join("; ") %>
                  <tr>
                    <td><%= record.data["stakeholder_category"].presence || "-" %></td>
                    <td><%= record.data["level_1_user"].presence || "-" %></td>
                    <td><%= record.data["level_2_user"].presence || Array(record.data["level_2_users"]).compact_blank.join(", ").presence || "-" %></td>
                    <td><%= level_3_display.presence || "-" %></td>
                    <td><%= record.created_at&.strftime("%d-%m-%Y %I:%M %p") %></td>
                    <td><span class="status-pill <%= record.data["status"] == "Inactive" ? "inactive" : "active" %>"><%= record.data["status"].presence || "Active" %></span></td>
                    <td>
                      <div class="table-actions">
                        <%= link_to "Edit", edit_module_record_path(@slug, record), class: "table-action" %>
                        <%= button_to(record.data["status"] == "Inactive" ? "Activate" : "Deactivate", toggle_module_record_path(@slug, record), method: :patch, class: "table-action") %>
                        <%= button_to "Delete", module_record_path(@slug, record), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this record?" } } %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7">No records saved yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="table-pagination" data-pagination-for="module_saved_records"></div>
      </section>
    </div>
  <% elsif @slug == "lg-directory-list" %>
    <section class="module-card lg-directory-card">
      <div class="module-card-header">
        <h2>All List</h2>
        <%= form_with url: import_module_path(@slug), method: :post, multipart: true, local: true, class: "lg-directory-upload" do |form| %>
          <label class="import-btn">
            Choose Excel
            <%= form.file_field :file, accept: ".xlsx,.csv", required: true, data: { import_file: true }, hidden: true %>
          </label>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
      </div>

      <%= form_with url: module_path(@slug), method: :get, local: true, class: "lg-directory-filter" do %>
        <label>
          <span>Select Table:</span>
          <select name="table">
            <% ["State Name", "State Code", "District Name", "District Code", "Block Name", "Block Code", "Gram Name", "Gram Code", "Village Name", "Village Code"].each do |field| %>
              <option value="<%= field %>" <%= "selected" if @lg_directory_filter == field %>><%= field %></option>
            <% end %>
          </select>
        </label>
        <label>
          <span>Enter Name:</span>
          <input type="search" name="q" value="<%= @lg_directory_query %>">
        </label>
        <button type="submit" class="list-btn upload">Search</button>
      <% end %>

      <%= form_with url: bulk_update_module_path(@slug), method: :patch, local: true do %>
        <div class="vrp-list-toolbar compact lg-directory-actions">
          <button type="submit" name="bulk_action" value="active" class="list-btn active">Active</button>
          <button type="submit" name="bulk_action" value="inactive" class="list-btn deactive">Inactive</button>
          <button type="submit" name="bulk_action" value="edit" class="list-btn edit">Edit</button>
          <button type="submit" name="bulk_action" value="delete" class="list-btn delete" data-turbo-confirm="Delete selected LG Directory row(s)?">Delete</button>
          <%= link_to "Export Excel", export_module_path(@slug, table: @lg_directory_filter, q: @lg_directory_query, format: :csv), class: "list-btn export" %>
        </div>

        <div class="table-shell lg-directory-table-shell">
          <table class="module-table user-list-table" id="lg_directory_all_list" data-paginated-table data-page-size="25">
            <thead>
              <tr>
                <th><input type="checkbox" data-module-select-all></th>
                <th>State Name</th>
                <th>State Code</th>
                <th>District Name</th>
                <th>District Code</th>
                <th>Block Name</th>
                <th>Block Code</th>
                <th>Gram Name</th>
                <th>Gram Code</th>
                <th>Village Name</th>
                <th>Village Code</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if @lg_directory_rows.any? %>
                <% @lg_directory_rows.each do |row| %>
                  <tr>
                    <td><input type="checkbox" name="row_tokens[]" value="<%= "#{row[:source_slug]}:#{row[:record_id]}" %>" data-module-row-select></td>
                    <td><%= row[:state].presence || "-" %></td>
                    <td><%= row[:state_code].presence || "-" %></td>
                    <td><%= row[:district].presence || "-" %></td>
                    <td><%= row[:district_code].presence || "-" %></td>
                    <td><%= row[:block].presence || "-" %></td>
                    <td><%= row[:block_code].presence || "-" %></td>
                    <td><%= row[:gram_panchayat].presence || "-" %></td>
                    <td><%= row[:gp_code].presence || "-" %></td>
                    <td><%= row[:village].presence || "-" %></td>
                    <td><%= row[:village_code].presence || "-" %></td>
                    <td><span class="status-pill <%= row[:status].to_s == "Inactive" ? "inactive" : "active" %>"><%= row[:status].presence || "Active" %></span></td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="12">No LG Directory records saved yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="table-pagination" data-pagination-for="lg_directory_all_list"></div>
      <% end %>
    </section>
  <% elsif @slug == "access-control" %>
    <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
    <% form_method = @record.present? ? :patch : :post %>
    <% selected_modules = Array(@record&.data&.[]("module_names")) %>
    <% selected_submodules = Array(@record&.data&.[]("sub_module_names").presence || @record&.data&.[]("sub_module_name")) %>
    <section class="module-card access-control-card">
      <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form", data: { user_role_form: true, role_map: json_escape(access_control_role_mappings.to_json) } } do %>
        <div class="access-top-grid">
          <% ["Stakeholder", "Stakeholder Role", "Role Name"].each do |field| %>
            <% field_key = field.parameterize(separator: "_") %>
            <% field_value = @record&.data&.[](field_key).to_s %>
            <% field_value = @record&.data&.[]("stakeholder_name").to_s if field == "Stakeholder" && field_value.blank? %>
            <% field_value = @record&.data&.[]("role").to_s if field == "Role Name" && field_value.blank? %>
            <% options = access_control_field_options(field, field_value) %>
            <% role_dependency_attr =
              case field
              when "Stakeholder"
                "data-role-stakeholder-select"
              when "Stakeholder Role"
                "data-stakeholder-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
              when "Role Name"
                "data-role-select data-role-prompt=\"Select Role Name\" data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
              end %>
            <label>
              <span><%= resource_person_label(field) %><% if field == "Stakeholder" %> <em>*</em><% end %></span>
              <% if options.any? %>
                <select name="module_record[<%= field_key %>]" <%= "required" if field == "Stakeholder" %> <%= role_dependency_attr&.html_safe %>>
                  <option value="">Select <%= resource_person_label(field) %></option>
                  <% options.each do |option| %>
                    <option value="<%= option %>" <%= "selected" if option == field_value %>><%= option %></option>
                  <% end %>
                </select>
              <% else %>
                <input name="module_record[<%= field_key %>]" type="text" value="<%= field_value %>" placeholder="Enter <%= resource_person_label(field) %>" <%= "required" if field == "Stakeholder" %>>
              <% end %>
            </label>
          <% end %>
        </div>

        <input type="hidden" name="module_record[can_view]" value="Yes">
        <input type="hidden" name="module_record[status]" value="Active">

        <div class="access-table-shell">
          <table class="module-table access-table">
            <thead>
              <tr>
                <th>Menu</th>
                <th>Sub Menu</th>
              </tr>
            </thead>
            <tbody>
              <% ApplicationHelper::SIDEBAR_SECTIONS.each do |section| %>
                <tr>
                  <td>
                    <label class="access-menu-check">
                      <input type="checkbox" name="module_record[module_names][]" value="<%= section[:title] %>" <%= "checked" if selected_modules.include?(section[:title]) %>>
                      <strong><%= section[:title] %></strong>
                    </label>
                  </td>
                  <td>
                    <div class="access-check-list">
                      <% section[:links].each do |link| %>
                        <% label = link.first %>
                        <label class="access-check">
                          <input type="checkbox" name="module_record[sub_module_names][]" value="<%= label %>" <%= "checked" if selected_submodules.include?(label) %>>
                          <%= label %>
                        </label>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="module-form-actions access-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update Access" : "Save Access" %></button>
        </div>
      <% end %>
    </section>

  <% elsif @slug == "vrp-bill-add" %>
    <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
    <% form_method = @record.present? ? :patch : :post %>
    <% raw_bill_items = @record&.data&.[]("bill_items") %>
    <% bill_items = raw_bill_items.is_a?(Hash) ? raw_bill_items.values : Array(raw_bill_items) %>
    <% selected_activity_groups = Array(@record&.data&.[]("select_activity_group")) %>
    <% selected_ics = Array(@record&.data&.[]("select_ics").presence || @record&.data&.[]("select_project")) %>
    <section class="module-card vrp-bill-card"
      data-vrp-bill-form
      data-activity-map="<%= json_escape(@bill_activity_map.to_json) %>"
      data-tci-map="<%= json_escape(@bill_tci_map.to_json) %>"
      data-village-options="<%= json_escape(@bill_village_options.to_json) %>">
      <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form", multipart: true } do %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Select VRP <em>*</em></span>
            <select name="module_record[select_vrp]" required>
              <option value="">Select VRP</option>
              <% @approved_vrp_options.each do |label, value| %>
                <option value="<%= value %>" <%= "selected" if @record&.data&.[]("select_vrp").to_s == value.to_s %>><%= label %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Select Financial Year <em>*</em></span>
            <select name="module_record[select_financial_year]" required>
              <option value="">Select Financial Year</option>
              <% @bill_financial_year_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if @record&.data&.[]("select_financial_year").to_s == option.to_s %>><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Select Bill Month <em>*</em></span>
            <select name="module_record[select_bill_month]" required>
              <option value="">Select Month</option>
              <% @bill_month_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if @record&.data&.[]("select_bill_month").to_s == option.to_s %>><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Select ICS <em>*</em></span>
            <select name="module_record[select_ics][]" data-bill-ics-select required>
              <option value="">Select ICS</option>
              <% @bill_project_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if selected_ics.include?(option) %>><%= option %></option>
              <% end %>
            </select>
          </label>

          <label>
            <span>Select Main Activity <em>*</em></span>
            <select name="module_record[select_activity_group][]" data-bill-activity-group required>
              <option value="">Select Main Activity</option>
              <% @bill_activity_group_options.each do |option| %>
                <option value="<%= option %>" <%= "selected" if selected_activity_groups.include?(option) %>><%= option %></option>
              <% end %>
            </select>
          </label>
        </div>

        <div class="bill-activity-shell" data-bill-activity-shell <%= "hidden" if bill_items.blank? && selected_activity_groups.blank? %>>
          <table class="module-table bill-activity-table">
            <thead>
              <tr>
                <th>Activity</th>
                <th>Task Completion Indicator</th>
                <th>No of Unit</th>
                <th>Rate</th>
                <th>Total Amount</th>
                <th>Remarks</th>
              </tr>
            </thead>
            <tbody data-bill-activity-rows>
              <% if bill_items.any? %>
                <% bill_items.each_with_index do |item, index| %>
                  <tr>
                    <td>
                      <%= item["activity"] %>
                      <input type="hidden" name="module_record[bill_items][<%= index %>][activity]" value="<%= item["activity"] %>">
                    </td>
                    <td>
                      <button type="button" class="tci-open-btn" data-open-tci-modal data-activity="<%= item["activity"] %>" data-row-index="<%= index %>">TCI</button>
                      <input type="hidden" name="module_record[bill_items][<%= index %>][tci_details]" value="<%= json_escape((item["tci_details"].presence || []).to_json) %>" data-tci-details-input>
                    </td>
                    <td><input type="number" min="0" step="1" name="module_record[bill_items][<%= index %>][no_of_unit]" value="<%= item["no_of_unit"].presence || 0 %>" data-bill-units></td>
                    <td><input type="number" min="0" step="0.01" name="module_record[bill_items][<%= index %>][rate]" value="<%= item["rate"].presence || 0 %>" data-bill-rate></td>
                    <td><input type="number" min="0" step="0.01" name="module_record[bill_items][<%= index %>][total_amount]" value="<%= item["total_amount"].presence || 0 %>" data-bill-total readonly></td>
                    <td><input type="text" name="module_record[bill_items][<%= index %>][remarks]" value="<%= item["remarks"] %>"></td>
                  </tr>
                <% end %>
              <% else %>
                <tr data-empty-bill-row>
                  <td colspan="6">Select Main Activity to load sub activities.</td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr>
                <th colspan="2">Grand Total</th>
                <td><input type="number" name="module_record[grand_units]" value="<%= @record&.data&.[]("grand_units").presence || 0 %>" data-grand-units readonly></td>
                <td></td>
                <td><input type="number" name="module_record[grand_total]" value="<%= @record&.data&.[]("grand_total").presence || 0 %>" data-grand-total readonly></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <input type="hidden" name="module_record[status]" value="<%= @record&.data&.[]("status").presence || "Pending" %>">

        <div class="module-form-actions bill-save-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary">Save VRP Bill</button>
        </div>
      <% end %>

      <dialog class="tci-modal" data-tci-modal>
        <div class="tci-modal-inner">
          <div class="tci-modal-header">
            <h2>Task Completion Indicators</h2>
            <button type="button" data-close-tci-modal aria-label="Close">×</button>
          </div>
          <div class="table-shell">
            <table class="module-table tci-entry-table">
              <thead>
                <tr>
                  <th>Indicator</th>
                  <th>Mandatory</th>
                  <th>Village</th>
                  <th>Working Date</th>
                  <th>Number</th>
                  <th></th>
                </tr>
              </thead>
              <tbody data-tci-modal-rows></tbody>
            </table>
          </div>
          <div class="module-form-actions">
            <button type="button" class="list-btn active" data-add-tci-row>Add More</button>
            <button type="button" class="btn btn-secondary" data-close-tci-modal>Cancel</button>
            <button type="button" class="list-btn active" data-apply-tci-modal>Apply</button>
          </div>
        </div>
      </dialog>
    </section>

  <% elsif @slug == "all-user" && @record.blank? %>
    <div class="vrp-list-toolbar">
      <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
      <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
      <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
      <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
    </div>

    <section class="module-card">
      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search users" data-table-search="all_user_list">
        </div>
        <div class="list-control-actions">
          <label class="import-btn">
            Choose Excel
            <input type="file" accept=".csv,.xlsx,.xls" data-import-file hidden>
          </label>
          <button type="button" class="list-btn upload" data-upload-selected>Upload</button>
          <button type="button" class="list-btn export" data-export-table="all_user_list">Export</button>
        </div>
      </div>
      <div class="table-shell">
        <table class="module-table user-list-table" id="all_user_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Full Name</th>
              <th>User Name</th>
              <th>Email</th>
              <th>Mobile No</th>
              <th>Stakeholder</th>
              <th>Role</th>
              <th>Person Type</th>
              <th>State</th>
              <th>District</th>
              <th>Block</th>
              <th>Gram Panchayat</th>
              <th>Village</th>
              <th>User Type</th>
              <th>Enrollment Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @records.any? %>
              <% @records.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_module_record_path(@slug, record) %>" data-module-row-select></td>
                  <td><%= [record.data["first_name"], record.data["last_name"]].compact_blank.join(" ").presence || "-" %></td>
                  <td><%= record.data["user_name"].presence || "-" %></td>
                  <td><%= record.data["email"].presence || "-" %></td>
                  <td><%= record.data["mobile_no"].presence || "-" %></td>
                  <td><%= record.data["stakeholder"].presence || "-" %></td>
                  <td><%= record.data["role"].presence || "-" %></td>
                  <td><%= record.data["person_type"].presence || "-" %></td>
                  <td><%= record.data["state"].presence || "-" %></td>
                  <td><%= record.data["district"].presence || "-" %></td>
                  <td><%= record.data["block"].presence || "-" %></td>
                  <td><%= record.data["gram_panchayat"].presence || "-" %></td>
                  <td><%= record.data["village"].presence || "-" %></td>
                  <td><%= record.data["user_type"].presence || "-" %></td>
                  <td><%= record.created_at&.strftime("%d-%m-%Y %I:%M %p") %></td>
                  <td><span class="status-pill <%= record.data["status"] == "Inactive" ? "inactive" : "active" %>"><%= record.data["status"].presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="16">No users registered yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="all_user_list"></div>
    </section>
  <% elsif list_only_slugs.include?(@slug) && @record.blank? %>
    <% table_id = "#{@slug.tr("-", "_")}_table" %>
    <section class="module-card list-only-card">
      <div class="module-card-header list-title-header">
        <h2><%= { "activity-group-list" => "All Main Activities", "vrp-activity-list" => "All Sub Activities", "task-completion-indicator-list" => "All Task Completion Indicators", "approval-list" => "All Approvals", "access-control-list" => "All Access Control", "vrp-bill-list" => "All VRP Bills", "training-form-list" => "All Training Records" }[@slug] %></h2>
      </div>

      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search records" data-table-search="<%= table_id %>">
        </div>
        <div class="list-control-actions">
          <label class="import-btn">
            Choose Excel
            <input type="file" accept=".csv,.xlsx,.xls" data-import-file hidden>
          </label>
          <button type="button" class="list-btn upload" data-upload-selected>Upload</button>
          <button type="button" class="list-btn export" data-export-table="<%= table_id %>">Export</button>
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table user-list-table" id="<%= table_id %>" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <% @module[:fields].each do |field| %>
                <th><%= resource_person_label(field) %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% if @records.any? %>
              <% @records.each do |record| %>
                <tr>
                  <% edit_slug = { "approval-list" => "approval-master", "access-control-list" => "access-control", "vrp-bill-list" => "vrp-bill-add", "training-form-list" => "training-form" }.fetch(@slug, @slug) %>
                  <td><input type="checkbox" value="<%= edit_module_record_path(edit_slug, record) %>" data-module-row-select></td>
                  <% @module[:fields].each do |field| %>
                    <% field_key = field.parameterize(separator: "_") %>
                    <% value = record.data[field_key].presence %>
                    <% value ||= record.data["activity_group_name"].presence if field == "Main Activity Name" %>
                    <% value ||= record.data["activity_group"].presence if field == "Main Activity" %>
                    <% value ||= record.data["activity_name"].presence || record.data["vrp_activity_name"].presence if field == "Sub Activity Name" %>
                    <% value ||= record.data["category_name"].presence || record.data["office"].presence if field == "Office Name" %>
                    <% value ||= Array(record.data["selected_farmer_names"]).join(", ").presence if field == "Selected Farmers" %>
                    <% if @slug == "access-control-list" && field == "Module Name" %>
                      <% value = Array(record.data["module_names"].presence || value).compact_blank %>
                    <% elsif @slug == "access-control-list" && field == "Sub Module Name" %>
                      <% value = Array(record.data["sub_module_names"].presence || record.data["sub_module_name"].presence || value).compact_blank %>
                    <% else %>
                      <% value ||= Array(record.data["module_names"]).join(", ").presence if field == "Module Name" %>
                      <% value ||= Array(record.data["sub_module_names"].presence || record.data["sub_module_name"]).join(", ").presence if field == "Sub Module Name" %>
                    <% end %>
                    <% value = value.join(", ") if value.is_a?(Array) %>
                    <% value ||= "-" %>
                    <% if field == "Status" %>
                      <td><span class="status-pill <%= value == "Inactive" ? "inactive" : "active" %>"><%= value == "-" ? "Active" : value %></span></td>
                    <% elsif @slug == "access-control-list" && ["Module Name", "Sub Module Name"].include?(field) %>
                      <% list_values = Array(value).flat_map { |item| item.to_s.split(",") }.map(&:strip).compact_blank %>
                      <td>
                        <div class="stacked-list-cell">
                          <% if list_values.any? %>
                            <% list_values.each do |item| %>
                              <span><%= item %></span>
                            <% end %>
                          <% else %>
                            <span>-</span>
                          <% end %>
                        </div>
                      </td>
                    <% else %>
                      <td><%= value %></td>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= @module[:fields].size + 1 %>">No records saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="<%= table_id %>"></div>
    </section>
  <% else %>
  <div class="module-grid">
    <% location_fields = ["State", "District", "Block", "Gram Panchayat", "Village"] %>
    <% has_location_fields = (@module[:fields] & location_fields).any? %>
    <section class="module-card" id="module-form" <% if ["role-management", "role-name", "user-management-role", "person-type"].include?(@slug) %>data-user-role-form data-role-map="<%= json_escape(role_management_mappings.to_json) %>"<% end %> <% if has_location_fields %>data-location-form data-location-map="<%= json_escape(location_hierarchy_mappings.to_json) %>"<% end %> <% if @slug == "training-form" %>data-training-target-form data-training-target-map="<%= json_escape(training_target_mappings.to_json) %>" data-training-activity-map="<%= json_escape(training_activity_mappings.to_json) %>"<% end %>>
      <div class="module-card-header">
        <h2><%= @slug == "new-user" ? "Registration" : (@record.present? ? "Edit Record" : "Fields") %></h2>
      </div>
      <% form_url = @record.present? ? module_record_path(@slug, @record) : records_module_path(@slug) %>
      <% form_method = @record.present? ? :patch : :post %>
      <%= form_with url: form_url, method: form_method, html: { class: "module-entry-form", multipart: true } do %>
        <% selected_training_farmer_ids = Array(@record&.data&.[]("selected_farmer_ids")).map(&:to_s) if @slug == "training-form" %>
        <div class="module-form-grid <%= "user-registration-grid" if @slug == "new-user" || (@slug == "all-user" && @record.present?) %>">
          <% @module[:fields].each do |field| %>
            <% field_key = field.parameterize(separator: "_") %>
            <% field_value = @record&.data&.[](field_key).to_s %>
            <% field_value = @record&.data&.[]("role_name").to_s if field == "Role" && field_value.blank? %>
            <% field_value = (@record&.data&.[]("category_name").presence || @record&.data&.[]("office")).to_s if field == "Office Name" && field_value.blank? %>
            <% if @slug == "training-form" && field_value.blank? %>
              <% field_value = current_app_user&.dig("name").to_s if field == "Trainer Name" %>
              <% field_value = current_app_user&.dig("mobile_no").to_s if field == "Trainer Contact" %>
              <% field_value = selected_training_farmer_ids.size.to_s if field == "Farmer Count" && selected_training_farmer_ids.present? %>
            <% end %>
            <label>
              <span>
                <%= resource_person_label(field) %>
                <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
                  <small class="field-hint inline-upload-hint">Max 5 MB</small>
                <% end %>
              </span>
              <% if field.downcase.include?("status") %>
                <select name="module_record[<%= field_key %>]">
                  <option <%= "selected" if field_value == "Active" %>>Active</option>
                  <option <%= "selected" if field_value == "Inactive" %>>Inactive</option>
                </select>
              <% elsif field.downcase.include?("upload") || field.downcase.include?("file") %>
                <input name="module_record[<%= field_key %>]" type="file" <%= "accept=\"image/*\" data-max-size-mb=\"5\"".html_safe if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>>
                <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
                  <input type="hidden" name="module_record[geo_latitude]" data-training-geo-latitude value="<%= @record&.data&.[]("geo_latitude") %>">
                  <input type="hidden" name="module_record[geo_longitude]" data-training-geo-longitude value="<%= @record&.data&.[]("geo_longitude") %>">
                <% end %>
                <% if field_value.present? %>
                  <small class="field-hint">Current: <%= field_value %></small>
                <% end %>
              <% elsif @slug == "training-topic-mapping" && field == "Department" %>
                <input name="module_record[<%= field_key %>]" type="text" placeholder="Enter <%= resource_person_label(field) %>" value="<%= field_value %>">
              <% elsif module_select_field?(field) %>
                <% options = (module_field_options(field) + static_field_options(field)).compact_blank.uniq %>
                <% role_dependency_attr =
                  case field
                  when "Stakeholder Category"
                    "data-role-stakeholder-select"
                  when "Stakeholder Role"
                    "data-stakeholder-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Role"
                    "data-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "User Management Role"
                    "data-user-management-role-select data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if ["role-management", "role-name", "user-management-role", "person-type"].include?(@slug) %>
                <% location_dependency_attr = "data-location-level=\"#{field.parameterize}\" data-selected-value=\"#{ERB::Util.html_escape(field_value)}\"" if location_fields.include?(field) %>
                <% training_target_attr =
                  case field
                  when "ICS / Block"
                    "data-training-target-ics data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Gram Name"
                    "data-training-target-village data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Department"
                    "data-training-department data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Training Topic"
                    "data-training-topic data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  when "Training Subject"
                    "data-training-subject data-selected-value=\"#{ERB::Util.html_escape(field_value)}\""
                  end if @slug == "training-form" %>
                <select name="module_record[<%= field_key %>]" <%= role_dependency_attr&.html_safe %> <%= location_dependency_attr&.html_safe %> <%= training_target_attr&.html_safe %>>
                  <option value=""><%= options.any? ? "Select #{resource_person_label(field)}" : "No #{resource_person_label(field)} saved yet" %></option>
                  <% options.each do |option| %>
                    <option value="<%= option %>" <%= "selected" if option == field_value %>><%= option %></option>
                  <% end %>
                </select>
              <% elsif field.downcase.include?("remarks") || field.downcase.include?("address") %>
                <textarea name="module_record[<%= field_key %>]" rows="3" placeholder="Enter <%= field %>"><%= field_value %></textarea>
              <% elsif field.downcase.include?("password") %>
                <input name="module_record[<%= field_key %>]" type="password" placeholder="Enter <%= field %>" value="<%= field_value %>">
              <% elsif field.downcase.include?("date") %>
                <input name="module_record[<%= field_key %>]" type="date" value="<%= field_value %>">
              <% else %>
                <input name="module_record[<%= field_key %>]" type="text" placeholder="Enter <%= resource_person_label(field) %>" value="<%= field_value %>" <%= "readonly" if @slug == "training-form" && ["Trainer Name", "Trainer Contact"].include?(field) && current_app_user&.dig("record_type").to_s == "Vrp" %> <%= "data-training-farmer-count-input" if @slug == "training-form" && field == "Farmer Count" %> <%= "data-user-management-role-input" if @slug == "role-management" && field == "User Management Role" %>>
              <% end %>
            </label>
            <% if @slug == "training-form" && field == "Training Photo Upload with Geo Tag" %>
              <div class="training-farmer-panel" data-training-farmer-panel data-selected-farmer-ids="<%= json_escape((selected_training_farmer_ids || []).to_json) %>">
                <div class="target-mapping-toolbar">
                  <strong>Mapped Farmers</strong>
                  <label class="training-select-all">
                    <input type="checkbox" data-training-farmer-select-all>
                    <span>Select all</span>
                  </label>
                  <button type="button" class="list-btn active training-select-all-button" data-training-farmer-select-all-button>Select all</button>
                  <span data-training-farmer-count>0 farmer selected</span>
                </div>
                <div class="vrp-ics-farmer-list" data-training-farmer-list>
                  Select Village Name to load mapped farmers.
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="module-form-actions">
          <%= link_to "Clear", module_path(@slug), class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary"><%= @record.present? ? "Update" : "Save" %></button>
        </div>
      <% end %>
    </section>

    <% unless @slug == "new-user" || entry_only_slugs.include?(@slug) %>
      <% saved_record_fields = @module[:fields].reject { |field| field == "Status" } %>
      <% saved_record_fields = saved_record_fields.first(4) unless @slug == "person-type" %>
      <section class="module-card">
        <div class="module-card-header">
          <h2>Saved Records</h2>
          <span class="record-count"><%= @records.size %> records</span>
        </div>
        <div class="list-controls">
          <div class="list-search">
            <span>⌕</span>
            <input type="search" placeholder="Search records" data-table-search="module_saved_records">
          </div>
          <%= form_with url: import_module_path(@slug), method: :post, multipart: true, local: true, class: "list-control-actions" do |form| %>
            <label class="import-btn">
              Choose Excel
              <%= form.file_field :file, accept: ".csv,.xlsx", data: { import_file: true }, hidden: true %>
            </label>
            <%= form.submit "Upload", class: "list-btn upload" %>
            <%= link_to "Export", export_module_path(@slug, format: :csv), class: "list-btn export" %>
          <% end %>
        </div>
        <div class="table-shell">
          <table class="module-table" id="module_saved_records" data-paginated-table data-page-size="15">
            <thead>
              <tr>
                <% saved_record_fields.each do |field| %>
                  <th><%= resource_person_label(field) %></th>
                <% end %>
                <th>Saved At</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @records.any? %>
                <% @records.each do |record| %>
                  <tr>
                    <% saved_record_fields.each do |field| %>
                      <td><%= record.data[field.parameterize(separator: "_")].presence || "-" %></td>
                    <% end %>
                    <td><%= record.created_at&.strftime("%d-%m-%Y %I:%M %p") %></td>
                    <td><span class="status-pill <%= record.data["status"] == "Inactive" ? "inactive" : "active" %>"><%= record.data["status"].presence || "Active" %></span></td>
                    <td>
                      <div class="table-actions">
                        <%= link_to "Edit", edit_module_record_path(@slug, record), class: "table-action" %>
                        <%= button_to(record.data["status"] == "Inactive" ? "Activate" : "Deactivate", toggle_module_record_path(@slug, record), method: :patch, class: "table-action") %>
                        <%= button_to "Delete", module_record_path(@slug, record), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this record?" } } %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="<%= saved_record_fields.size + 3 %>">No records saved yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="table-pagination" data-pagination-for="module_saved_records"></div>
      </section>
    <% end %>
  </div>
  <% end %>

  <% if @module[:features].present? %>
    <div class="module-grid">
      <% if @module[:features].present? %>
        <section class="module-card">
          <div class="module-card-header">
            <h2>Features</h2>
          </div>
          <div class="chip-list">
            <% @module[:features].each do |feature| %>
              <span><%= feature %></span>
            <% end %>
          </div>
        </section>
      <% end %>

    </div>
  <% end %>
</section>
