<% content_for :title, "Disease, Insects, Pests & Weed Management Record" %>
<% form_record = @disease_record %>
<% form_url = form_record.persisted? ? disease_pest_weed_management_record_path(form_record) : disease_pest_weed_management_records_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Farmer Farm Information</p>
        <h1>Disease, Insects, Pests & Weed Management Record</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_disease_pest_weed_management_records_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_disease_pest_weed_management_records_path, class: "list-btn export" %>
        </div>
      </div>
    </div>

    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Name of farm /plot no.</span>
            <%= f.text_field :farm_plot_no, placeholder: "Enter Farm / Plot No" %>
          </label>
          <label>
            <span>Area</span>
            <%= f.number_field :area, step: "0.0001", min: 0, placeholder: "Enter Area" %>
          </label>
          <label>
            <span>Name of the crop</span>
            <%= f.text_field :crop_name, placeholder: "Enter Crop Name" %>
          </label>
          <label>
            <span>Name of pest, disease and weed</span>
            <%= f.text_field :pest_disease_weed_name, placeholder: "Enter Pest / Disease / Weed" %>
          </label>
          <label>
            <span>Treatment used for control - Name</span>
            <%= f.text_field :treatment_name, placeholder: "Enter Treatment Name" %>
          </label>
          <label>
            <span>Treatment used for control - Time</span>
            <%= f.text_field :treatment_time, placeholder: "Enter Treatment Time" %>
          </label>
          <label>
            <span>Source / brand of input</span>
            <%= f.text_field :input_source_brand, placeholder: "Enter Source / Brand" %>
          </label>
          <label>
            <span>Rate of application</span>
            <%= f.text_field :application_rate, placeholder: "Enter Rate of Application" %>
          </label>
          <label>
            <span>Status</span>
            <%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %>
          </label>
        </div>

        <div class="module-form-actions">
          <%= link_to form_record.persisted? ? "Cancel Edit" : "Clear", disease_pest_weed_management_records_path, class: "btn btn-secondary" %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search disease pest weed records" data-table-search="disease_pest_weed_records_list">
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="disease_pest_weed_records_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Farm / Plot No</th>
              <th>Area</th>
              <th>Crop</th>
              <th>Pest / Disease / Weed</th>
              <th>Treatment Name</th>
              <th>Treatment Time</th>
              <th>Source / Brand</th>
              <th>Rate</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @disease_records.any? %>
              <% @disease_records.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_disease_pest_weed_management_record_path(record) %>" data-module-row-select></td>
                  <td><%= record.farm_plot_no.presence || "-" %></td>
                  <td><%= record.area.presence || "-" %></td>
                  <td><%= record.crop_name.presence || "-" %></td>
                  <td><%= record.pest_disease_weed_name.presence || "-" %></td>
                  <td><%= record.treatment_name.presence || "-" %></td>
                  <td><%= record.treatment_time.presence || "-" %></td>
                  <td><%= record.input_source_brand.presence || "-" %></td>
                  <td><%= record.application_rate.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="10">No disease, pest and weed management record saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="disease_pest_weed_records_list"></div>
    </section>
  </section>
</main>
