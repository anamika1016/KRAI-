<% content_for :title, "Contamination Control Records" %>
<% form_record = @contamination_record %>
<% form_url = form_record.persisted? ? contamination_control_record_path(form_record) : contamination_control_records_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Farmer Farm Information</p>
        <h1>Contamination Control Records</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_contamination_control_records_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_contamination_control_records_path, class: "list-btn export" %>
        </div>
      </div>
    </div>

    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Chances of contamination</span>
            <%= f.select :chance_of_contamination, options_for_select(@chance_options, form_record.chance_of_contamination), { include_blank: "Select Chance" } %>
          </label>
          <label>
            <span>Source & Details</span>
            <%= f.text_area :source_details, rows: 3, placeholder: "Enter Source & Details" %>
          </label>
          <label>
            <span>Time of contamination control</span>
            <%= f.text_field :contamination_control_time, placeholder: "Enter Time" %>
          </label>
          <label>
            <span>Contamination management - Prevention</span>
            <%= f.text_field :prevention, placeholder: "Enter Prevention" %>
          </label>
          <label>
            <span>Contamination management - Control</span>
            <%= f.text_field :control, placeholder: "Enter Control" %>
          </label>
          <label>
            <span>Remarks</span>
            <%= f.text_area :remarks, rows: 3, placeholder: "Enter Remarks" %>
          </label>
          <label>
            <span>Status</span>
            <%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %>
          </label>
        </div>

        <div class="module-form-actions">
          <%= link_to form_record.persisted? ? "Cancel Edit" : "Clear", contamination_control_records_path, class: "btn btn-secondary" %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search contamination records" data-table-search="contamination_control_records_list">
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="contamination_control_records_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Chances of contamination</th>
              <th>Source & Details</th>
              <th>Time</th>
              <th>Prevention</th>
              <th>Control</th>
              <th>Remarks</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @contamination_records.any? %>
              <% @contamination_records.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_contamination_control_record_path(record) %>" data-module-row-select></td>
                  <td><%= record.chance_of_contamination.presence || "-" %></td>
                  <td><%= record.source_details.presence || "-" %></td>
                  <td><%= record.contamination_control_time.presence || "-" %></td>
                  <td><%= record.prevention.presence || "-" %></td>
                  <td><%= record.control.presence || "-" %></td>
                  <td><%= record.remarks.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8">No contamination control record saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="contamination_control_records_list"></div>
    </section>
  </section>
</main>
