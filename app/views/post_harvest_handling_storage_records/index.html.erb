<% content_for :title, "Post Harvest, Handling & Storage Area" %>
<% form_record = @post_harvest_handling_storage_record %>
<% form_url = form_record.persisted? ? post_harvest_handling_storage_record_path(form_record) : post_harvest_handling_storage_records_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Farmer Farm Information</p>
        <h1>Record of Post Harvest, Handling & Storage Area</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_post_harvest_handling_storage_records_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_post_harvest_handling_storage_records_path, class: "list-btn export" %>
        </div>
      </div>
    </div>

    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Name of crop</span>
            <%= f.text_field :crop_name, placeholder: "Enter Crop Name" %>
          </label>
          <label>
            <span>Post harvest treatment</span>
            <%= f.text_area :post_harvest_treatment, rows: 3, placeholder: "Harvesting, Threshing, Winnowing, Cleaning" %>
          </label>
          <label>
            <span>Name of produce</span>
            <%= f.text_field :produce_name, placeholder: "Enter Produce Name" %>
          </label>
          <label>
            <span>Packing Material</span>
            <%= f.text_field :packing_material, placeholder: "Enter Packing Material" %>
          </label>
          <label>
            <span>Storage area</span>
            <%= f.text_field :storage_area, placeholder: "Enter Storage Area" %>
          </label>
          <label>
            <span>Status</span>
            <%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %>
          </label>
        </div>

        <div class="module-form-actions">
          <% if form_record.persisted? %>
            <%= link_to "Cancel Edit", post_harvest_handling_storage_records_path, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to "Clear", post_harvest_handling_storage_records_path, class: "btn btn-secondary" %>
          <% end %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search post harvest records" data-table-search="post_harvest_handling_storage_records_list">
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="post_harvest_handling_storage_records_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Name of crop</th>
              <th>Post harvest treatment</th>
              <th>Name of produce</th>
              <th>Packing Material</th>
              <th>Storage area</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @post_harvest_handling_storage_records.any? %>
              <% @post_harvest_handling_storage_records.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_post_harvest_handling_storage_record_path(record) %>" data-module-row-select></td>
                  <td><%= record.crop_name.presence || "-" %></td>
                  <td><%= record.post_harvest_treatment.presence || "-" %></td>
                  <td><%= record.produce_name.presence || "-" %></td>
                  <td><%= record.packing_material.presence || "-" %></td>
                  <td><%= record.storage_area.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7">No post harvest handling storage records saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="post_harvest_handling_storage_records_list"></div>
    </section>
  </section>
</main>
