<% content_for :title, "VRP ICS Mapping" %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">AFL</p>
        <h1>VRP ICS Mapping</h1>
      </div>
    </div>

    <section class="module-card vrp-ics-card"
      data-vrp-ics-mapping
      data-edit-mapping="<%= json_escape(@edit_payload.to_json) %>"
      data-ics-url="<%= ics_options_vrp_ics_mappings_path %>"
      data-villages-url="<%= village_options_vrp_ics_mappings_path %>"
      data-farmers-url="<%= farmers_vrp_ics_mappings_path %>">
      <%= form_with url: vrp_ics_mappings_path, method: :post, local: true, html: { class: "module-entry-form" } do %>
        <% if @edit_mapping %>
          <input type="hidden" name="vrp_ics_mapping[id]" value="<%= @edit_mapping.id %>">
        <% end %>
        <div class="module-form-grid vrp-ics-grid">
          <label>
            Approved VRP
            <select name="vrp_ics_mapping[vrp_id]" data-vrp-ics-vrp required>
              <option value="">Select VRP</option>
              <% @approved_vrps.each do |vrp| %>
                <option value="<%= vrp.id %>" <%= "selected" if @edit_mapping&.vrp_id == vrp.id %>><%= [vrp.name, vrp.mobile_no.presence].compact.join(" - ") %></option>
              <% end %>
            </select>
          </label>

          <label>
            FCO Name
            <select name="vrp_ics_mapping[fco_id]" data-vrp-ics-fco required>
              <option value="">Select FCO</option>
              <% @fco_options.each do |option| %>
                <option value="<%= option[:value] %>" <%= "selected" if @edit_mapping&.fco_id.to_s == option[:value].to_s %>><%= option[:label] %></option>
              <% end %>
            </select>
            <input type="hidden" name="vrp_ics_mapping[fco_name]" data-vrp-ics-fco-name>
          </label>

          <label>
            ICS
            <select name="vrp_ics_mapping[ics_id]" data-vrp-ics-ics required disabled>
              <option value="">Select ICS</option>
            </select>
            <input type="hidden" name="vrp_ics_mapping[ics_name]" data-vrp-ics-ics-name>
          </label>

          <label>
            Village
            <select name="vrp_ics_mapping[village_id]" data-vrp-ics-village required disabled>
              <option value="">Select Village</option>
            </select>
            <input type="hidden" name="vrp_ics_mapping[village_name]" data-vrp-ics-village-name>
          </label>
        </div>

        <div class="vrp-ics-farmer-panel">
          <div class="vrp-ics-farmer-toolbar">
            <label class="vrp-ics-select-all">
              <input type="checkbox" data-vrp-ics-select-all>
              Select all
            </label>
            <strong data-vrp-ics-count>0 farmer selected</strong>
          </div>
          <div class="vrp-ics-farmer-list" data-vrp-ics-farmers>
            Select FCO, ICS and Village to load farmers.
          </div>
        </div>

        <div class="module-form-actions">
          <% if @edit_mapping %>
            <%= link_to "Cancel Edit", vrp_ics_mappings_path, class: "btn btn-secondary" %>
          <% end %>
          <button type="submit" class="list-btn upload"><%= @edit_mapping ? "Update Mapping" : "Save Mapping" %></button>
        </div>
      <% end %>
    </section>

    <div class="vrp-list-card">
      <div class="list-controls">
        <strong>Recent VRP ICS Mappings</strong>
      </div>
      <div class="table-shell">
        <table class="module-table vrp-list-table" id="vrp_ics_mapping_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th>VRP</th>
              <th>FCO</th>
              <th>ICS</th>
              <th>Village</th>
              <th>Farmers</th>
              <th>Updated</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if @mappings.any? %>
              <% @mappings.each do |mapping| %>
                <tr>
                  <td><%= mapping.vrp&.name %></td>
                  <td><%= mapping.fco_name.presence || mapping.fco_id %></td>
                  <td><%= mapping.ics_name.presence || mapping.ics_id %></td>
                  <td><%= mapping.village_name.presence || mapping.village_id %></td>
                  <td><%= mapping.farmer_count %></td>
                  <td><%= mapping.updated_at&.strftime("%d-%m-%Y") %></td>
                  <td>
                    <div class="table-actions">
                      <%= link_to "Edit", vrp_ics_mappings_path(edit_id: mapping.id), class: "table-action" %>
                      <%= button_to "Delete", vrp_ics_mapping_path(mapping), method: :delete, class: "table-action danger", form: { data: { turbo_confirm: "Delete this VRP ICS mapping?" } } %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7">No VRP ICS mapping saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="vrp_ics_mapping_list"></div>
    </div>
  </section>
</main>
