<% content_for :title, "On Farm Input Records" %>
<% form_record = @on_farm_input_record %>
<% form_url = form_record.persisted? ? on_farm_input_record_path(form_record) : on_farm_input_records_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header"><div><p class="vrp-eyebrow">Farmer Farm Information</p><h1>On Farm Input Records</h1></div></div>
    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_on_farm_input_records_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_on_farm_input_records_path, class: "list-btn export" %>
        </div>
      </div>
    </div>
    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label><span>S No.</span><%= f.text_field :serial_no, placeholder: "Enter S No." %></label>
          <label><span>Name of Input</span><%= f.text_field :input_name, placeholder: "Enter Input Name" %></label>
          <label><span>Date of input preparation</span><%= f.date_field :preparation_date %></label>
          <label><span>Details of raw material used</span><%= f.text_area :raw_material_details, rows: 3, placeholder: "Enter Raw Material Details" %></label>
          <label><span>Quantity of input prepared</span><%= f.number_field :prepared_quantity, step: "0.0001", min: 0, placeholder: "Enter Quantity" %></label>
          <label><span>Status</span><%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %></label>
        </div>
        <div class="module-form-actions">
          <%= link_to form_record.persisted? ? "Cancel Edit" : "Clear", on_farm_input_records_path, class: "btn btn-secondary" %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>
      <div class="list-controls"><div class="list-search"><span>⌕</span><input type="search" placeholder="Search on farm input records" data-table-search="on_farm_input_records_list"></div></div>
      <div class="table-shell">
        <table class="module-table vrp-list-table" id="on_farm_input_records_list" data-paginated-table data-page-size="15">
          <thead><tr><th><input type="checkbox" data-module-select-all></th><th>S No.</th><th>Input</th><th>Preparation Date</th><th>Raw Material</th><th>Prepared Quantity</th><th>Status</th></tr></thead>
          <tbody>
            <% if @on_farm_input_records.any? %>
              <% @on_farm_input_records.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_on_farm_input_record_path(record) %>" data-module-row-select></td>
                  <td><%= record.serial_no.presence || "-" %></td>
                  <td><%= record.input_name.presence || "-" %></td>
                  <td><%= record.preparation_date&.strftime("%d-%m-%Y") || "-" %></td>
                  <td><%= record.raw_material_details.presence || "-" %></td>
                  <td><%= record.prepared_quantity.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr><td colspan="7">No on farm input record saved yet.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="on_farm_input_records_list"></div>
    </section>
  </section>
</main>
