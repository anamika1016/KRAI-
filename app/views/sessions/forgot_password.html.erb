<% content_for :title, "Forget Password" %>

<main class="forgot-password-page">
  <section class="forgot-password-card" aria-label="Forgot Password">
    <div class="forgot-password-card-inner">
      <h1>Forget Password</h1>

      <% if notice.present? %>
        <div class="login-notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="login-notice alert"><%= alert %></div>
      <% end %>

      <%= form_with url: send_forgot_password_otp_path, method: :post, local: true, html: { class: "forgot-password-form", data: { turbo: false } } do |form| %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= form.text_field :username, name: :username, value: @forgot_username, placeholder: "Username", required: true, autocomplete: "username", class: "forgot-password-input" %>
        <button type="submit" class="forgot-password-btn secondary">Get OTP</button>
      <% end %>

      <%= form_with url: reset_forgot_password_path, method: :post, local: true, html: { class: "forgot-password-form", data: { turbo: false } } do |form| %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :username, @forgot_username %>
        <div class="forgot-otp-row">
          <%= form.text_field :otp_code, name: :otp_code, placeholder: "OTP Code", inputmode: "numeric", maxlength: 4, class: "forgot-password-input" %>
        </div>

        <%= form.password_field :password, name: :password, placeholder: "Password", autocomplete: "new-password", class: "forgot-password-input" %>
        <%= form.password_field :confirmed_password, name: :confirmed_password, placeholder: "Confirm Password", autocomplete: "new-password", class: "forgot-password-input" %>

        <button type="submit" class="forgot-password-btn primary">Reset Password</button>
      <% end %>

      <div class="forgot-password-footer">
        <%= link_to login_path do %>
          <span>↪</span>
          Sign In
        <% end %>
      </div>
    </div>
  </section>
</main>
