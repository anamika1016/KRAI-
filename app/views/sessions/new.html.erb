<main class="login-page">
  <section class="login-panel" aria-label="Login">
    <div class="login-surface">
      <h1>Login</h1>

      <% if notice.present? %>
        <div class="login-notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="login-notice alert"><%= alert %></div>
      <% end %>

      <%= form_with url: login_path, method: :post, html: { class: "login-form" } do |f| %>
        <div>
          <%= f.label :login, "Username", class: "form-label" %>
          <%= f.text_field :login, class: "form-control", placeholder: "Username / Email / Mobile", required: true %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "form-label" %>
          <div class="login-password-field">
            <%= f.password_field :password, class: "form-control", placeholder: "Password", required: true, data: { password_toggle_input: true } %>
            <button type="button" class="password-eye-btn" data-password-toggle aria-label="Show password" title="Show password">&#128065;</button>
          </div>
        </div>

        <div class="login-options">
          <label>
            <%= check_box_tag :remember_me, "1" %>
            Keep me logged in.
          </label>
        </div>

        <%= f.submit "GO!", class: "btn btn-primary login-submit" %>
      <% end %>
    </div>
  </section>
</main>
