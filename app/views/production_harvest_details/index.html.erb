<% content_for :title, "Records of Production & Harvest Details" %>
<% form_record = @production_harvest_detail %>
<% form_url = form_record.persisted? ? production_harvest_detail_path(form_record) : production_harvest_details_path %>
<% form_method = form_record.persisted? ? :patch : :post %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Farmer Farm Information</p>
        <h1>Records of Production & Harvest Details</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_production_harvest_details_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>
        <div class="list-control-actions">
          <%= link_to "Export Excel", export_production_harvest_details_path, class: "list-btn export" %>
        </div>
      </div>
    </div>

    <section class="module-card">
      <%= form_with model: form_record, url: form_url, method: form_method, local: true, html: { class: "module-entry-form" } do |f| %>
        <div class="module-form-grid user-registration-grid">
          <label>
            <span>Name of farm /plot</span>
            <%= f.text_field :farm_plot_name, placeholder: "Enter Farm / Plot" %>
          </label>
          <label>
            <span>Year & season</span>
            <%= f.text_field :year_season, placeholder: "Enter Year & Season" %>
          </label>
          <label>
            <span>Name of the crop/produce</span>
            <%= f.text_field :crop_produce_name, placeholder: "Enter Crop / Produce" %>
          </label>
          <label>
            <span>Area (Ha)</span>
            <%= f.number_field :area_hectares, step: "0.0001", min: 0, placeholder: "Enter Area" %>
          </label>
          <label>
            <span>Estimated production (MT)</span>
            <%= f.number_field :estimated_production_mt, step: "0.0001", min: 0, placeholder: "Enter Estimated Production" %>
          </label>
          <label>
            <span>Time of harvest</span>
            <%= f.text_field :harvest_time, placeholder: "Enter Harvest Time" %>
          </label>
          <label>
            <span>Actual production (MT)</span>
            <%= f.number_field :actual_production_mt, step: "0.0001", min: 0, placeholder: "Enter Actual Production" %>
          </label>
          <label>
            <span>Status</span>
            <%= f.select :status, options_for_select(["Active", "Inactive"], form_record.status.presence || "Active") %>
          </label>
        </div>

        <div class="module-form-actions">
          <% if form_record.persisted? %>
            <%= link_to "Cancel Edit", production_harvest_details_path, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to "Clear", production_harvest_details_path, class: "btn btn-secondary" %>
          <% end %>
          <%= f.submit form_record.persisted? ? "Update" : "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>

    <section class="module-card">
      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn active" data-module-status-selected="Active">Active</button>
        <button type="button" class="list-btn deactive" data-module-status-selected="Inactive">Deactive</button>
        <button type="button" class="list-btn edit" data-module-edit-selected>Edit</button>
        <button type="button" class="list-btn delete" data-module-delete-selected>Delete</button>
      </div>

      <div class="list-controls">
        <div class="list-search">
          <span>⌕</span>
          <input type="search" placeholder="Search production harvest details" data-table-search="production_harvest_details_list">
        </div>
      </div>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="production_harvest_details_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-module-select-all></th>
              <th>Name of farm /plot</th>
              <th>Year & season</th>
              <th>Crop/produce</th>
              <th>Area (Ha)</th>
              <th>Estimated production (MT)</th>
              <th>Time of harvest</th>
              <th>Actual production (MT)</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @production_harvest_details.any? %>
              <% @production_harvest_details.each do |record| %>
                <tr>
                  <td><input type="checkbox" value="<%= edit_production_harvest_detail_path(record) %>" data-module-row-select></td>
                  <td><%= record.farm_plot_name.presence || "-" %></td>
                  <td><%= record.year_season.presence || "-" %></td>
                  <td><%= record.crop_produce_name.presence || "-" %></td>
                  <td><%= record.area_hectares.presence || "-" %></td>
                  <td><%= record.estimated_production_mt.presence || "-" %></td>
                  <td><%= record.harvest_time.presence || "-" %></td>
                  <td><%= record.actual_production_mt.presence || "-" %></td>
                  <td><span class="status-pill <%= record.status == "Inactive" ? "inactive" : "active" %>"><%= record.status.presence || "Active" %></span></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="9">No production harvest details saved yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination" data-pagination-for="production_harvest_details_list"></div>
    </section>
  </section>
</main>
