<% content_for :title, "AFL Upload" %>

<main class="vrp-list-page">
  <section class="vrp-list-shell">
    <div class="vrp-list-header">
      <div>
        <p class="vrp-eyebrow">Target Mapping</p>
        <h1>AFL Upload</h1>
      </div>
    </div>

    <div class="vrp-list-card">
      <div class="list-controls">
        <%= form_with url: import_afls_path, multipart: true, local: true, class: "list-search" do |form| %>
          <span>▤</span>
          <%= form.file_field :file, accept: ".xlsx,.csv", class: "form-control", required: true %>
          <%= form.submit "Upload", class: "list-btn upload" %>
        <% end %>

        <div class="list-control-actions">
          <%= form_with url: afls_path, method: :get, local: true, class: "list-search compact" do |form| %>
            <span>⌕</span>
            <%= form.search_field :q, value: @query, placeholder: "Search any field", data: { table_search: "afl_list" } %>
          <% end %>
          <button type="button" class="list-btn export" data-export-table="afl_list">Export</button>
        </div>
      </div>

      <div class="vrp-list-toolbar compact">
        <button type="button" class="list-btn delete" data-afl-delete-selected data-afl-bulk-destroy-url="<%= bulk_destroy_afls_path %>">Delete</button>
      </div>

      <% if params[:report_id].present? %>
        <div class="import-report-banner">
          <span>Skipped rows ka exact reason report ready hai.</span>
          <%= link_to "Download skipped report", import_report_afls_path(params[:report_id]), class: "table-action" %>
        </div>
      <% end %>

      <div class="table-shell">
        <table class="module-table vrp-list-table" id="afl_list" data-paginated-table data-page-size="15">
          <thead>
            <tr>
              <th><input type="checkbox" data-afl-select-all></th>
              <th>ID</th>
              <th>FCO ID</th>
              <th>FCO</th>
              <th>FPO ID</th>
              <th>FPO Name</th>
              <th>ICS ID</th>
              <th>ICS Name</th>
              <th>Village ID</th>
              <th>Village Name</th>
              <th>Farmer Name</th>
              <th>Father Name</th>
              <th>Tracenet No</th>
              <th>Total Farm Area</th>
              <th>Purchase Quantity Amount</th>
              <th>Estimate Quantity</th>
              <th>Purchase Quantity</th>
              <th>Purchase Date</th>
              <th>Mobile No</th>
              <th>Purchase Product</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if @afls.any? %>
              <% @afls.each do |afl| %>
                <tr>
                  <td><input type="checkbox" value="<%= afl_path(afl, q: @query.presence, page: @page) %>" data-afl-row-select></td>
                  <td><%= afl.id %></td>
                  <td><%= afl.fco_id %></td>
                  <td><%= afl.fco %></td>
                  <td><%= afl.fpo_id %></td>
                  <td><%= afl.fpo_name %></td>
                  <td><%= afl.ics_id %></td>
                  <td><%= afl.ics_name %></td>
                  <td><%= afl.village_id %></td>
                  <td><%= afl.village_name %></td>
                  <td><%= afl.farmer_name %></td>
                  <td><%= afl.father_name %></td>
                  <td><%= afl.tracenet_no %></td>
                  <td><%= afl.total_farm_area %></td>
                  <td><%= afl.purchase_quantity_amount %></td>
                  <td><%= afl.estimate_quantity %></td>
                  <td><%= afl.purchase_quantity %></td>
                  <td><%= afl.purchase_date&.strftime("%d-%m-%Y") %></td>
                  <td><%= afl.mobile_no %></td>
                  <td><%= afl.purchase_product %></td>
                  <td><%= afl.status %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="21">No target mapping records uploaded yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="table-pagination">
        <% start_count = @total_afls.zero? ? 0 : ((@page - 1) * @page_size) + 1 %>
        <% end_count = [@page * @page_size, @total_afls].min %>
        <span><%= start_count %> to <%= end_count %> of <%= @total_afls %></span>
        <% if @page > 1 %>
          <%= link_to "‹", afls_path(q: @query.presence, page: @page - 1), class: "page-link" %>
        <% else %>
          <span class="page-link disabled">‹</span>
        <% end %>
        <strong>Page <%= @page %> of <%= @total_pages %></strong>
        <% if @page < @total_pages %>
          <%= link_to "›", afls_path(q: @query.presence, page: @page + 1), class: "page-link" %>
        <% else %>
          <span class="page-link disabled">›</span>
        <% end %>
      </div>
    </div>
  </section>
</main>
